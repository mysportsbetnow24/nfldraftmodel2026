---
import meta from "../data/build_meta.json";
import "../styles/site-ui.css";

interface Props {
  title: string;
  description?: string;
  collectionSchema?: Record<string, unknown> | null;
  ogImage?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description = "2026 NFL Draft big board, mocks, scouting cards, and player comparison tools.",
  collectionSchema = null,
  ogImage = "/og-default.svg",
  ogType = "website"
} = Astro.props;
const siteUrl = (Astro.site ?? new URL("https://scoutinggrade.com")).toString().replace(/\/$/, "");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Scouting Grade",
  url: siteUrl
};
const generatedAt = (meta as { generated_at?: string }).generated_at || "";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Scouting Grade" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Scouting Grade - 2026 NFL Draft data and scouting hub" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Scouting Grade - 2026 NFL Draft data and scouting hub" />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    {collectionSchema && <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />}
  </head>
  <body>
    <div class="shell">
      <header class="header">
        <div class="brand"><a href="/">Scouting Grade</a></div>
        <nav class="nav">
          <a href="/2026-nfl-draft-big-board">Big Board</a>
          <a href="/2026-nfl-mock-draft">Mock Draft</a>
          <a href="/2026-nfl-7-round-mock-draft">7-Round Mock</a>
          <a href="/nfl-team-needs-2026">Team Needs</a>
          <a href="/nfl-transactions-feed-2026">Transactions</a>
          <a href="/2026-nfl-player-comparison">Player Compare</a>
          <a href="/scouting-cards">Scouting Cards</a>
          <a href="/nfl-draft-methodology">Approach</a>
          <a href="/2026-nfl-draft-weekly-updates">Updates</a>
        </nav>
      </header>
      <slot />
      <footer class="footer">
        Scouting Grade · Data-driven NFL Draft modeling and scouting synthesis.
        {generatedAt && <span> · Last updated (UTC): {generatedAt}</span>}
      </footer>
    </div>
  </body>
</html>
