---
import meta from "../data/build_meta.json";

interface Props {
  title: string;
  description?: string;
  collectionSchema?: Record<string, unknown> | null;
  ogImage?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description = "2026 NFL Draft big board, mocks, scouting cards, and player comparison tools.",
  collectionSchema = null,
  ogImage = "/og-default.svg",
  ogType = "website"
} = Astro.props;
const siteUrl = (Astro.site ?? new URL("https://scoutinggrade.com")).toString().replace(/\/$/, "");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Scouting Grade",
  url: siteUrl
};
const generatedAt = (meta as { generated_at?: string }).generated_at || "";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Scouting Grade" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Scouting Grade - 2026 NFL Draft data and scouting hub" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Scouting Grade - 2026 NFL Draft data and scouting hub" />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    {collectionSchema && <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />}
    <style>
      :root {
        --bg: #f3f5f8;
        --surface: #ffffff;
        --line: #d8dce2;
        --ink: #111827;
        --muted: #5c6473;
        --brand: #0d2f4f;
        --accent: #138a4a;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--ink);
        font-family: "SF Pro Text", "Segoe UI", Inter, system-ui, sans-serif;
        background:
          radial-gradient(circle at 10% 0%, rgba(13,47,79,0.08), transparent 45%),
          radial-gradient(circle at 90% 10%, rgba(19,138,74,0.08), transparent 40%),
          var(--bg);
      }
      .shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.25rem;
      }
      .header {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        padding: 0.8rem 0;
      }
      .brand {
        font-size: 1.55rem;
        font-weight: 800;
        letter-spacing: 0.01em;
      }
      .brand a { color: var(--ink); text-decoration: none; }
      .nav {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
      }
      .nav a {
        text-decoration: none;
        color: var(--brand);
        border: 1px solid var(--line);
        background: #fff;
        border-radius: 999px;
        padding: 0.45rem 0.72rem;
        font-size: 0.9rem;
        font-weight: 600;
      }
      .hero {
        border: 1px solid var(--line);
        background: linear-gradient(135deg, #0e2238, #0f3b63);
        color: #fff;
        border-radius: 18px;
        padding: 1.45rem;
        margin-bottom: 1rem;
      }
      .hero h1 {
        margin: 0 0 0.35rem;
        font-size: clamp(1.55rem, 4vw, 2.5rem);
        line-height: 1.08;
      }
      .hero p {
        margin: 0;
        color: rgba(255,255,255,0.9);
      }
      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 0.95rem;
      }
      .section-title {
        margin: 0 0 0.65rem;
        font-size: 1.2rem;
        letter-spacing: -0.01em;
      }
      .table-wrap {
        overflow: auto;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: #fff;
      }
      .filters-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 0.6rem;
        margin-bottom: 0.95rem;
      }
      .control {
        padding: 0.66rem 0.74rem;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: #fff;
        font: inherit;
        color: inherit;
        min-width: 0;
      }
      .control:focus-visible {
        outline: 2px solid rgba(25, 90, 173, 0.26);
        outline-offset: 1px;
      }
      .result-bar {
        display: flex;
        justify-content: space-between;
        gap: 0.65rem;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 0.9rem;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid #ccd4df;
        padding: 0.12rem 0.45rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.01em;
      }
      .chip.info {
        color: #245ea8;
        border-color: #b9cfe9;
        background: #eef5fc;
      }
      .chip.good {
        color: #0f5d2e;
        border-color: #a9d8b8;
        background: #edf9f0;
      }
      .chip.warn {
        color: #8a3f2f;
        border-color: #e7c1b7;
        background: #fdf1ee;
      }
      .reset-btn {
        border: 1px solid var(--line);
        background: #fff;
        padding: 0.48rem 0.72rem;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 600;
      }
      .reset-btn:hover { background: #f7fafc; }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.92rem;
      }
      thead th {
        text-align: left;
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        border-bottom: 1px solid var(--line);
        padding: 0.55rem 0.45rem;
      }
      tbody td {
        border-bottom: 1px solid #edf0f4;
        padding: 0.52rem 0.45rem;
      }
      tbody tr:hover { background: #f8fafc; }
      .muted { color: var(--muted); }
      .badge {
        display: inline-block;
        padding: 0.2rem 0.45rem;
        border-radius: 999px;
        border: 1px solid #c7cfda;
        font-size: 0.76rem;
        font-weight: 700;
      }
      .footer {
        color: var(--muted);
        font-size: 0.82rem;
        padding: 1rem 0 2rem;
      }
      @media (max-width: 820px) {
        .shell { padding: 0.7rem; }
        table { font-size: 0.84rem; }
        .filters-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="header">
        <div class="brand"><a href="/">Scouting Grade</a></div>
        <nav class="nav">
          <a href="/2026-nfl-draft-big-board">Big Board</a>
          <a href="/2026-nfl-mock-draft">Mock Draft</a>
          <a href="/2026-nfl-7-round-mock-draft">7-Round Mock</a>
          <a href="/nfl-team-needs-2026">Team Needs</a>
          <a href="/nfl-transactions-feed-2026">Transactions</a>
          <a href="/2026-nfl-player-comparison">Player Compare</a>
          <a href="/scouting-cards">Scouting Cards</a>
          <a href="/nfl-draft-methodology">Approach</a>
          <a href="/2026-nfl-draft-weekly-updates">Updates</a>
        </nav>
      </header>
      <slot />
      <footer class="footer">
        Scouting Grade · Data-driven NFL Draft modeling and scouting synthesis.
        {generatedAt && <span> · Last updated (UTC): {generatedAt}</span>}
      </footer>
    </div>
  </body>
</html>
