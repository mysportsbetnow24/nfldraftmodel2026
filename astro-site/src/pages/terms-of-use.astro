---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Terms of Use | Scouting Grade";
const description =
  "Terms of use for Scouting Grade, including ownership, permitted use, and restrictions on scraping, republication, and automated extraction.";
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath="/terms-of-use"
>
  <main class="page-shell">
    <section class="hero hero--data">
      <p class="eyebrow">Legal</p>
      <h1>Terms of Use</h1>
      <p class="hero-copy">
        Scouting Grade publishes proprietary NFL Draft grades, rankings, scouting reports, and team-building analysis.
      </p>
    </section>

    <section class="card prose-card">
      <h2>Ownership</h2>
      <p>
        All grades, rankings, scouting writeups, player comparisons, visualizations, data presentation, and site content
        published on Scouting Grade are owned by Scouting Grade unless otherwise noted.
      </p>

      <h2>Permitted Use</h2>
      <p>
        You may browse the site for personal, non-commercial use and cite short excerpts with attribution and a link back
        to the original page.
      </p>

      <h2>Restricted Use</h2>
      <p>
        You may not scrape, harvest, republish, mirror, resell, systematically extract, or use automated tools to copy
        substantial portions of the site, its rankings, scouting reports, structured data, or proprietary grading outputs
        without prior written permission.
      </p>

      <h2>AI and Automated Extraction</h2>
      <p>
        Scouting Grade does not authorize the use of this site or its content for AI training, model improvement,
        automated knowledge-base ingestion, or large-scale content extraction without prior written permission.
      </p>

      <h2>No License Granted</h2>
      <p>
        Accessing the site does not grant any license or ownership interest in Scouting Grade intellectual property beyond
        limited personal viewing rights.
      </p>

      <h2>Contact</h2>
      <p>
        For licensing, partnerships, or permission requests, contact the site owner directly through your listed business
        channel.
      </p>
    </section>
  </main>
</BaseLayout>
