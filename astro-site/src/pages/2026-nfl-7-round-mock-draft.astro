---
import BaseLayout from "../layouts/BaseLayout.astro";
import picks from "../data/mock_2026_7round.json";
import byTeam from "../data/mock_2026_7round_by_team.json";

const teams = Object.keys(byTeam || {}).sort();
const preferredPositionOrder = ["QB", "RB", "WR", "TE", "OT", "IOL", "DT", "EDGE", "LB", "CB", "S"];
const pickPositions = Array.from(new Set((picks || []).map((p: any) => p.position).filter(Boolean)));
const positions = [
  ...preferredPositionOrder.filter((p) => pickPositions.includes(p)),
  ...pickPositions.filter((p) => !preferredPositionOrder.includes(p)).sort(),
];
const rounds = Array.from(
  new Set((picks || []).map((p: any) => Number(p.round)).filter((r) => Number.isFinite(r) && r > 0))
).sort((a, b) => a - b);
const schools = Array.from(new Set((picks || []).map((p: any) => p.school).filter(Boolean))).sort();
const pageDescription = "2026 7-round NFL mock draft with full pick order, team filters, and complete projected draft classes.";
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "2026 7-Round NFL Mock Draft",
  url: "https://scoutinggrade.com/2026-nfl-7-round-mock-draft",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "2026 7-Round NFL Mock Draft Picks",
  itemListOrder: "https://schema.org/ItemListOrderAscending",
  numberOfItems: (picks || []).length,
  itemListElement: (picks || []).map((p: any) => ({
    "@type": "ListItem",
    position: Number(p.overall_pick),
    name: `${p.team} - ${p.player_name}`,
    url: p.player_report_url ? `https://scoutinggrade.com${p.player_report_url}` : "https://scoutinggrade.com/2026-nfl-7-round-mock-draft",
  })),
};
---
<BaseLayout
  title="2026 7-Round NFL Mock Draft | Full Picks"
  description={pageDescription}
  keywords={["2026 7-round nfl mock draft", "full nfl mock draft 2026", "nfl draft projections", "scouting grade"]}
  collectionSchema={collectionSchema}
  extraSchemas={[itemListSchema]}
>
  <section class="hero hero--data">
    <h1>2026 7-Round NFL Mock Draft</h1>
    <p>Full draft projection with team-level class filtering.</p>
  </section>

  <section class="card filter-card">
    <h2 class="section-title">Filter And Sort</h2>
    <div class="filters-grid">
      <input id="searchFilter" type="search" placeholder="Search player, school, or position..." class="control search-control" />
      <select id="teamFilter" class="control">
        <option value="">All Teams</option>
        {teams.map((team) => <option value={team}>{team}</option>)}
      </select>
      <select id="roundFilter" class="control">
        <option value="">All Rounds</option>
        {rounds.map((r) => <option value={String(r)}>{`Round ${r}`}</option>)}
      </select>
      <select id="positionFilter" class="control">
        <option value="">All Positions</option>
        {positions.map((p) => <option value={p}>{p}</option>)}
      </select>
      <select id="schoolFilter" class="control">
        <option value="">All Schools</option>
        {schools.map((s) => <option value={s}>{s}</option>)}
      </select>
      <select id="sortBy" class="control">
        <option value="overall_asc">Sort: Overall pick (asc)</option>
        <option value="overall_desc">Sort: Overall pick (desc)</option>
        <option value="round_asc">Sort: Round then pick</option>
        <option value="position_az">Sort: Position (A-Z)</option>
        <option value="school_az">Sort: School (A-Z)</option>
      </select>
    </div>
    <div class="result-bar">
      <span id="teamSummary" class="muted">Showing all picks.</span>
      <button id="resetFilters" type="button" class="reset-btn">Reset Filters</button>
    </div>
  </section>

  <section class="card">
    <h2 class="section-title">7-Round Projection</h2>
    <div class="table-wrap">
      <table id="mockTable">
        <thead>
          <tr>
            <th>Overall</th>
            <th>Round</th>
            <th>Team</th>
            <th>Player</th>
            <th>Pos</th>
            <th>School</th>
            <th>Grade</th>
          </tr>
        </thead>
        <tbody>
          {picks.map((p: any) => (
            <tr
              data-team={p.team}
              data-round={p.round}
              data-position={p.position}
              data-school={p.school}
              data-overall={p.overall_pick}
              data-player={p.player_name}
              data-search={`${String(p.player_name || "")} ${String(p.position || "")} ${String(p.school || "")}`.toLowerCase()}
            >
              <td>{p.overall_pick}</td>
              <td>{p.round}</td>
              <td>{p.team}</td>
              <td>
                {p.player_report_url ? (
                  <a class="player-link" href={p.player_report_url}>{p.player_name}</a>
                ) : (
                  p.player_name
                )}
              </td>
              <td><span class="badge">{p.position}</span></td>
              <td>{p.school}</td>
              <td>{p.final_grade}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <script define:vars={{ byTeam }}>
    const searchFilter = document.getElementById("searchFilter");
    const teamFilter = document.getElementById("teamFilter");
    const roundFilter = document.getElementById("roundFilter");
    const positionFilter = document.getElementById("positionFilter");
    const schoolFilter = document.getElementById("schoolFilter");
    const sortBy = document.getElementById("sortBy");
    const resetFilters = document.getElementById("resetFilters");
    const rows = Array.from(document.querySelectorAll("#mockTable tbody tr"));
    const tbody = document.querySelector("#mockTable tbody");
    const summary = document.getElementById("teamSummary");

    const cmp = (a, b) => (a < b ? -1 : a > b ? 1 : 0);

    const update = () => {
      const team = teamFilter?.value || "";
      const round = roundFilter?.value || "";
      const pos = positionFilter?.value || "";
      const school = schoolFilter?.value || "";
      const q = (searchFilter?.value || "").toLowerCase().trim();
      const sort = sortBy?.value || "overall_asc";

      const filtered = rows.filter((row) => {
        const hay = row.getAttribute("data-search") || "";
        if (q && !hay.includes(q)) return false;
        if (team && row.getAttribute("data-team") !== team) return false;
        if (round && row.getAttribute("data-round") !== round) return false;
        if (pos && row.getAttribute("data-position") !== pos) return false;
        if (school && row.getAttribute("data-school") !== school) return false;
        return true;
      });

      const sorted = [...filtered].sort((a, b) => {
        const aOverall = Number(a.getAttribute("data-overall") || 9999);
        const bOverall = Number(b.getAttribute("data-overall") || 9999);
        const aRound = Number(a.getAttribute("data-round") || 99);
        const bRound = Number(b.getAttribute("data-round") || 99);
        const aPos = a.getAttribute("data-position") || "";
        const bPos = b.getAttribute("data-position") || "";
        const aSchool = a.getAttribute("data-school") || "";
        const bSchool = b.getAttribute("data-school") || "";

        if (sort === "overall_desc") return bOverall - aOverall;
        if (sort === "round_asc") return (aRound - bRound) || (aOverall - bOverall);
        if (sort === "position_az") return cmp(aPos, bPos) || (aOverall - bOverall);
        if (sort === "school_az") return cmp(aSchool, bSchool) || (aOverall - bOverall);
        return aOverall - bOverall;
      });

      rows.forEach((row) => {
        row.style.display = "none";
      });
      sorted.forEach((row) => {
        row.style.display = "";
        if (tbody) tbody.appendChild(row);
      });

      let shown = 0;
      sorted.forEach(() => {
        shown += 1;
      });

      if (!summary) return;
      if (!q && !team && !round && !pos && !school) {
        summary.textContent = `Showing all picks (${shown}).`;
        return;
      }

      const parts = [];
      if (team) {
        const cls = byTeam[team] || [];
        const byPos = {};
        cls.forEach((p) => {
          byPos[p.position] = (byPos[p.position] || 0) + 1;
        });
        const posTxt = Object.entries(byPos).map(([k, v]) => `${k} ${v}`).join(", ");
        parts.push(`${team}: ${cls.length} picks (${posTxt || "no picks"})`);
      }
      if (round) parts.push(`Round ${round}`);
      if (pos) parts.push(pos);
      if (school) parts.push(school);
      if (q) parts.push(`search: ${q}`);
      summary.textContent = `Showing ${shown} picks${parts.length ? " · " + parts.join(" · ") : ""}.`;
    };

    [searchFilter, teamFilter, roundFilter, positionFilter, schoolFilter, sortBy].forEach((el) => {
      if (el) el.addEventListener("change", update);
      if (el) el.addEventListener("input", update);
    });

    if (resetFilters) {
      resetFilters.addEventListener("click", () => {
        if (searchFilter) searchFilter.value = "";
        if (teamFilter) teamFilter.value = "";
        if (roundFilter) roundFilter.value = "";
        if (positionFilter) positionFilter.value = "";
        if (schoolFilter) schoolFilter.value = "";
        if (sortBy) sortBy.value = "overall_asc";
        update();
      });
    }

    update();
  </script>

</BaseLayout>
