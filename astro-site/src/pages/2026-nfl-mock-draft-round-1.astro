---
import BaseLayout from "../layouts/BaseLayout.astro";
import picks from "../data/mock_2026_round1.json";

const preferredPositionOrder = ["QB", "RB", "WR", "TE", "OT", "IOL", "DT", "EDGE", "LB", "CB", "S"];
const round1Positions = Array.from(new Set((picks || []).map((p: any) => p.position).filter(Boolean)));
const positions = [
  ...preferredPositionOrder.filter((p) => round1Positions.includes(p)),
  ...round1Positions.filter((p) => !preferredPositionOrder.includes(p)).sort(),
];
const teams = Array.from(new Set((picks || []).map((p: any) => p.team).filter(Boolean))).sort();
const schools = Array.from(new Set((picks || []).map((p: any) => p.school).filter(Boolean))).sort();

const pageDescription = "2026 NFL Mock Draft Round 1 with pick-by-pick projections, team fits, and model grades.";
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "2026 NFL Mock Draft Round 1",
  url: "https://scoutinggrade.com/2026-nfl-mock-draft-round-1",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
const pickList = (picks || []).slice(0, 32).map((p: any) => ({
  "@type": "ListItem",
  position: Number(p.overall_pick),
  name: `${p.team} - ${p.player_name}`,
  url: p.player_report_url ? `https://scoutinggrade.com${p.player_report_url}` : "https://scoutinggrade.com/2026-nfl-mock-draft-round-1",
}));
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "2026 NFL Mock Draft Round 1 Picks",
  itemListOrder: "https://schema.org/ItemListOrderAscending",
  numberOfItems: pickList.length,
  itemListElement: pickList,
};
---
<BaseLayout
  title="2026 NFL Mock Draft Round 1 Picks | Scouting Grade"
  description={pageDescription}
  keywords={["2026 nfl mock draft", "2026 nfl mock draft round 1", "nfl draft first round mock", "scouting grade"]}
  collectionSchema={collectionSchema}
  extraSchemas={[itemListSchema]}
>
  <section class="hero hero--data">
    <h1>2026 NFL Mock Draft (Round 1)</h1>
    <p>Latest first-round projection from the current model and team-need logic.</p>
  </section>

  <section class="card filter-card">
    <h2 class="section-title">Filter And Sort</h2>
    <div class="filters-grid">
      <input id="searchFilter" type="search" placeholder="Search player, school, or position..." class="control search-control" />
      <select id="teamFilter" class="control">
        <option value="">All Teams</option>
        {teams.map((team) => <option value={team}>{team}</option>)}
      </select>
      <select id="positionFilter" class="control">
        <option value="">All Positions</option>
        {positions.map((p) => <option value={p}>{p}</option>)}
      </select>
      <select id="schoolFilter" class="control">
        <option value="">All Schools</option>
        {schools.map((s) => <option value={s}>{s}</option>)}
      </select>
      <select id="sortBy" class="control">
        <option value="pick_asc">Sort: Pick (asc)</option>
        <option value="pick_desc">Sort: Pick (desc)</option>
        <option value="grade_desc">Sort: Grade (desc)</option>
        <option value="position_az">Sort: Position (A-Z)</option>
        <option value="school_az">Sort: School (A-Z)</option>
      </select>
    </div>
    <div class="result-bar">
      <span id="summaryText" class="muted">Showing all round 1 picks.</span>
      <button id="resetFilters" type="button" class="reset-btn">Reset Filters</button>
    </div>
  </section>

  <section class="card">
    <h2 class="section-title">Round 1 Projection</h2>
    <div class="table-wrap">
      <table id="round1MockTable">
        <thead>
          <tr>
            <th>Pick</th>
            <th>Team</th>
            <th>Player</th>
            <th>Pos</th>
            <th>School</th>
            <th>Grade</th>
            <th>Round Value</th>
          </tr>
        </thead>
        <tbody>
          {picks.map((p: any) => (
            <tr
              data-team={p.team}
              data-position={p.position}
              data-school={p.school}
              data-pick={p.overall_pick}
              data-grade={p.final_grade}
              data-search={`${String(p.player_name || "")} ${String(p.position || "")} ${String(p.school || "")}`.toLowerCase()}
            >
              <td>{p.overall_pick}</td>
              <td>{p.team}</td>
              <td>
                {p.player_report_url ? (
                  <a class="player-link" href={p.player_report_url}>{p.player_name}</a>
                ) : (
                  p.player_name
                )}
              </td>
              <td><span class="badge">{p.position}</span></td>
              <td>{p.school}</td>
              <td>{p.final_grade}</td>
              <td>{p.round_value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <script>
    (() => {
      const searchFilter = document.getElementById("searchFilter");
      const teamFilter = document.getElementById("teamFilter");
      const positionFilter = document.getElementById("positionFilter");
      const schoolFilter = document.getElementById("schoolFilter");
      const sortBy = document.getElementById("sortBy");
      const resetFilters = document.getElementById("resetFilters");
      const summary = document.getElementById("summaryText");
      const tbody = document.querySelector("#round1MockTable tbody");
      const rows = Array.from(document.querySelectorAll("#round1MockTable tbody tr"));

      const cmp = (a, b) => (a < b ? -1 : a > b ? 1 : 0);

      function update() {
        const team = teamFilter?.value || "";
        const pos = positionFilter?.value || "";
        const school = schoolFilter?.value || "";
        const q = (searchFilter?.value || "").toLowerCase().trim();
        const sort = sortBy?.value || "pick_asc";

        const filtered = rows.filter((row) => {
          const hay = row.getAttribute("data-search") || "";
          if (q && !hay.includes(q)) return false;
          if (team && row.getAttribute("data-team") !== team) return false;
          if (pos && row.getAttribute("data-position") !== pos) return false;
          if (school && row.getAttribute("data-school") !== school) return false;
          return true;
        });

        const sorted = [...filtered].sort((a, b) => {
          const aPick = Number(a.getAttribute("data-pick") || 9999);
          const bPick = Number(b.getAttribute("data-pick") || 9999);
          const aGrade = Number(a.getAttribute("data-grade") || 0);
          const bGrade = Number(b.getAttribute("data-grade") || 0);
          const aPos = a.getAttribute("data-position") || "";
          const bPos = b.getAttribute("data-position") || "";
          const aSchool = a.getAttribute("data-school") || "";
          const bSchool = b.getAttribute("data-school") || "";

          if (sort === "pick_desc") return bPick - aPick;
          if (sort === "grade_desc") return bGrade - aGrade || (aPick - bPick);
          if (sort === "position_az") return cmp(aPos, bPos) || (aPick - bPick);
          if (sort === "school_az") return cmp(aSchool, bSchool) || (aPick - bPick);
          return aPick - bPick;
        });

        rows.forEach((row) => {
          row.style.display = "none";
        });

        sorted.forEach((row) => {
          row.style.display = "";
          if (tbody) tbody.appendChild(row);
        });

        if (summary) {
          const parts = [];
          if (team) parts.push(team);
          if (pos) parts.push(pos);
          if (school) parts.push(school);
          if (q) parts.push(`search: ${q}`);
          summary.textContent = `Showing ${sorted.length} picks${parts.length ? " · " + parts.join(" · ") : ""}.`;
        }
      }

      [searchFilter, teamFilter, positionFilter, schoolFilter, sortBy].forEach((el) => {
        if (el) el.addEventListener("change", update);
        if (el) el.addEventListener("input", update);
      });

      if (resetFilters) {
        resetFilters.addEventListener("click", () => {
          if (searchFilter) searchFilter.value = "";
          if (teamFilter) teamFilter.value = "";
          if (positionFilter) positionFilter.value = "";
          if (schoolFilter) schoolFilter.value = "";
          if (sortBy) sortBy.value = "pick_asc";
          update();
        });
      }

      update();
    })();
  </script>

</BaseLayout>
