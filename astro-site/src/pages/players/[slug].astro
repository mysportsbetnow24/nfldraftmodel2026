---
import BaseLayout from "../../layouts/BaseLayout.astro";
import board from "../../data/big_board_2026.json";

export function getStaticPaths() {
  return (board || []).map((p: any) => ({
    params: { slug: p.slug },
    props: { player: p }
  }));
}

const { player } = Astro.props;
const playerUrl = `https://scoutinggrade.com/players/${player.slug}`;
const pageDescription = String(player.seo_description_override || "").trim()
  || `${player.player_name} ${player.position} scouting report with grade, round projection, production snapshot, and role fit for the 2026 NFL Draft.`;
const profileSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: `${player.player_name} Scouting Report`,
  url: playerUrl,
  description: pageDescription,
  mainEntity: {
    "@type": "SportsPerson",
    name: player.player_name,
    description: pageDescription,
    alumniOf: player.school,
    knowsAbout: [`${player.position} play`, "NFL Draft scouting"],
    additionalProperty: [
      { "@type": "PropertyValue", name: "Model Grade", value: Number(player.final_grade || 0) || "" },
      { "@type": "PropertyValue", name: "Model Rank", value: Number(player.consensus_rank || 0) || "" },
      { "@type": "PropertyValue", name: "Round Value", value: player.round_value || "" },
      { "@type": "PropertyValue", name: "PFF Grade", value: Number(player.pff_grade || 0) || "" },
      { "@type": "PropertyValue", name: "RAS Score", value: Number(player.combine_ras_official || 0) || Number(player.ras_estimate || 0) || "" },
    ],
  },
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Scouting Grade", item: "https://scoutinggrade.com/" },
    { "@type": "ListItem", position: 2, name: "2026 NFL Draft Big Board", item: "https://scoutinggrade.com/2026-nfl-draft-big-board" },
    { "@type": "ListItem", position: 3, name: player.player_name, item: playerUrl },
  ],
};
const ras = Number(player.combine_ras_official || 0) > 0 ? Number(player.combine_ras_official).toFixed(2) : (Number(player.ras_estimate || 0) > 0 ? `${Number(player.ras_estimate).toFixed(2)} (est.)` : "-");
const concernsText = String(player.scouting_primary_concerns || "");
const riskKeywords = [
  "medical",
  "character",
  "off-field",
  "discipline",
  "legal",
  "suspension",
  "injury concern",
  "concussion",
  "acl",
  "mcl",
  "achilles",
  "fracture",
];
const hasMedicalCharacterRisk = riskKeywords.some((k) => concernsText.toLowerCase().includes(k));
const productionPctRaw = Number(player.production_composite_pct ?? "");
const productionPct = Number.isFinite(productionPctRaw) ? Math.max(0, Math.min(100, productionPctRaw)) : 50;
const rasRaw = Number(player.combine_ras_official || 0) > 0 ? Number(player.combine_ras_official || 0) : Number(player.ras_estimate || 0);
const athleticPctRaw = Number(player.athletic_percentile ?? "");
const athleticPct = Number.isFinite(athleticPctRaw) && athleticPctRaw >= 0
  ? Math.max(0, Math.min(100, athleticPctRaw))
  : (Number.isFinite(rasRaw) && rasRaw > 0 ? Math.max(0, Math.min(100, ((rasRaw - 4) / 6) * 100)) : 50);
const athleticTestingRaw = Number(player.athletic_testing_score ?? "");
const athleticTestingScore = Number.isFinite(athleticTestingRaw) && athleticTestingRaw >= 0
  ? Math.max(0, Math.min(100, athleticTestingRaw))
  : 50;
const athleticFrameRaw = Number(player.athletic_frame_score ?? "");
const athleticFrameScore = Number.isFinite(athleticFrameRaw) && athleticFrameRaw >= 0
  ? Math.max(0, Math.min(100, athleticFrameRaw))
  : 50;
const athleticConfidenceRaw = Number(player.athletic_source_confidence ?? "");
const athleticConfidence = Number.isFinite(athleticConfidenceRaw) && athleticConfidenceRaw >= 0
  ? Math.max(0, Math.min(100, athleticConfidenceRaw))
  : 50;
const traitPctRaw = Number(player.trait_percentile ?? "");
const traitRaw = Number(player.trait_score || 0);
const traitPct = Number.isFinite(traitPctRaw) && traitPctRaw >= 0
  ? Math.max(0, Math.min(100, traitPctRaw))
  : (Number.isFinite(traitRaw) && traitRaw > 0 ? Math.max(0, Math.min(100, ((traitRaw - 70) / 27) * 100)) : 50);
const marketRaw = Number(player.market_signal_pct || 50);
const marketPct = Number.isFinite(marketRaw) ? Math.max(0, Math.min(100, marketRaw)) : 50;
const advancedRows = Array.isArray(player.advanced_metric_cards) ? player.advanced_metric_cards : [];
const countRows = Array.isArray(player.counting_stat_chips) ? player.counting_stat_chips : [];
const positionLens = player && typeof player.position_lens === "object" && Array.isArray(player.position_lens.rows)
  ? player.position_lens
  : null;
const toBullets = (value: string) =>
  String(value || "")
    .replace(/\\n/g, "\n")
    .split(/\n+/)
    .map((line) => String(line || "").trim())
    .filter(Boolean)
    .map((line) => line.replace(/^(?:[-*•]\s*|\d+\.\s*)/, "").trim());
const toParagraphs = (value: string) =>
  String(value || "")
    .split(/\n{2,}/)
    .map((part) => String(part || "").trim())
    .filter(Boolean);
const winsBullets = toBullets(String(player.scouting_why_he_wins || ""));
const concernBullets = toBullets(String(player.scouting_primary_concerns || ""));
const filmNoteBullets = toBullets(String(player.scouting_film_notes || ""));
const summaryParagraphs = toParagraphs(String(player.scouting_report_summary || ""));
const roleParagraphs = toParagraphs(String(player.scouting_role_projection || ""));
const roleChips = [String(player.best_role || "").trim(), String(player.best_scheme_fit || "").trim(), ...(positionLens?.tags || [])]
  .filter(Boolean);
const compLine = (title: string, comp: any, fallback: string) => {
  if (!comp || !comp.name) return `${title}: ${fallback}`;
  const simRaw = Number(comp.similarity);
  const sim = Number.isFinite(simRaw) ? (simRaw <= 1 ? simRaw * 100 : simRaw) : null;
  const simText = sim !== null ? `${sim.toFixed(1)}%` : "-";
  const yearText = comp.year ? ` (${comp.year})` : "";
  return `${title}: ${comp.name}${yearText} · ${simText} profile similarity`;
};
---
<BaseLayout
  title={`${player.player_name} Scouting Report 2026 NFL Draft | Scouting Grade`}
  description={pageDescription}
  keywords={["2026 nfl draft scouting report", `${String(player.player_name || "").toLowerCase()} scouting report`, `${String(player.position || "").toLowerCase()} draft prospect`, "scouting grade"]}
  collectionSchema={profileSchema}
  extraSchemas={[breadcrumbSchema]}
>
  <section class="hero hero--data">
    <h1>{player.player_name}</h1>
    <p>{player.position} · {player.school} · 2026 NFL Draft Prospect</p>
  </section>

  <section class="card summary-card">
    <div class="stat-grid">
      <div class="card"><strong>Model Rank</strong><div>{player.consensus_rank}</div></div>
      <div class="card"><strong>Model Grade</strong><div>{player.final_grade}</div></div>
      <div class="card"><strong>Round Range</strong><div>{player.round_value}</div></div>
      <div class="card"><strong>PFF Grade</strong><div>{Number(player.pff_grade || 0) > 0 ? Number(player.pff_grade).toFixed(1) : "-"}</div></div>
      <div class="card"><strong>Trait Score</strong><div>{Number(player.trait_score || 0) > 0 ? Number(player.trait_score).toFixed(2) : "-"}</div></div>
      <div class="card"><strong>RAS Score</strong><div>{ras}</div></div>
    </div>
    <div class="badge-row">
      <span class="badge">Top Driver: {String(player.top_rank_driver || "n/a").toUpperCase()} ({Number(player.top_rank_driver_delta) >= 0 ? "+" : ""}{player.top_rank_driver_delta})</span>
      {hasMedicalCharacterRisk ? <span class="badge warn">Risk Watch: medical/character item noted</span> : null}
    </div>
  </section>

  <section class="card detail-grid">
    <article class="card">
      <h2 class="block-title">Report Summary</h2>
      {summaryParagraphs.length ? (
        <div class="summary-stack muted">
          {summaryParagraphs.map((item: string) => <p class="block-copy report-summary">{item}</p>)}
        </div>
      ) : (
        <p class="muted block-copy report-summary">No scouting summary available yet.</p>
      )}
    </article>
    <article class="card">
      <h2 class="block-title">Translation Snapshot</h2>
      <div class="bar-metrics">
        <div class="metric-row">
          <div class="metric-top"><span>Production Percentile</span><strong>{productionPct.toFixed(0)}th pct</strong></div>
          <div class="meter"><div class="meter-fill" style={`width:${productionPct.toFixed(1)}%;background:#0f7b6a;`}></div></div>
          <div class="muted athletic-copy">Measures how strong the player&apos;s current production profile looks versus this draft class at the same position.</div>
        </div>
        <div class="metric-row">
          <div class="metric-top"><span>Athletic Profile Percentile</span><strong>{athleticPct.toFixed(0)}th pct</strong></div>
          <div class="meter"><div class="meter-fill" style={`width:${athleticPct.toFixed(1)}%;background:#425466;`}></div></div>
          <div class="muted athletic-copy">Blends verified testing, frame context, and position-adjusted athletic history.</div>
          <div class="athletic-subgrid">
            <div class="athletic-subrow"><span>Testing Profile</span><strong>{athleticTestingScore.toFixed(0)}/100</strong></div>
            <div class="athletic-subrow"><span>Frame Profile</span><strong>{athleticFrameScore.toFixed(0)}/100</strong></div>
            <div class="athletic-subrow"><span>Confidence</span><strong>{athleticConfidence.toFixed(0)}%</strong></div>
          </div>
        </div>
        <div class="metric-row">
          <div class="metric-top"><span>Trait Percentile</span><strong>{traitPct.toFixed(0)}th pct</strong></div>
          <div class="meter"><div class="meter-fill" style={`width:${traitPct.toFixed(1)}%;background:#245ea8;`}></div></div>
          <div class="muted athletic-copy">Captures the player&apos;s projected NFL tool set for the position: movement skills, functional traits, and role translation.</div>
        </div>
        <div class="metric-row">
          <div class="metric-top"><span>Market Signal</span><strong>{marketPct.toFixed(0)}th pct</strong></div>
          <div class="meter"><div class="meter-fill" style={`width:${marketPct.toFixed(1)}%;background:#0ea5e9;`}></div></div>
          <div class="muted athletic-copy">Shows how strongly the broader draft market supports this evaluation relative to peers at the same position.</div>
        </div>
      </div>
    </article>
    <article class="card">
      <h2 class="block-title">How He Wins</h2>
      {winsBullets.length ? (
        <ul class="scout-list muted">
          {winsBullets.map((item: string) => <li>{item}</li>)}
        </ul>
      ) : <div class="muted">How he wins assessment updates as scouting notes refresh.</div>}
    </article>
    <article class="card">
      <h2 class="block-title">Primary Concerns</h2>
      {concernBullets.length ? (
        <ul class="scout-list muted">
          {concernBullets.map((item: string) => <li>{item}</li>)}
        </ul>
      ) : <div class="muted">No major concerns flagged in the current profile.</div>}
    </article>
    <article class="card">
      <h2 class="block-title">Film Notes</h2>
      {filmNoteBullets.length ? (
        <ul class="scout-list muted">
          {filmNoteBullets.map((item: string) => <li>{item}</li>)}
        </ul>
      ) : <div class="muted">Film notes will appear here as scouting updates are published.</div>}
    </article>
    <article class="card">
      <h2 class="block-title">{player.production_snapshot_heading || "2025 Production Snapshot"}</h2>
      {advancedRows.length ? (
        <div class="bar-metrics">
          {advancedRows.map((m:any) => (
            <div class="metric-row">
              <div class="metric-top"><span>{m.label}</span><strong>{m.display} · {Number(m.pct || 50).toFixed(0)}th pct</strong></div>
              <div class="meter"><div class="meter-fill" style={`width:${m.pct.toFixed(1)}%;background:#0f7b6a;`}></div></div>
            </div>
          ))}
        </div>
      ) : null}
      {countRows.length ? (
        <div class="chip-row" style="margin-top:0.9rem;">
          {countRows.map((m:any) => <span class="chip info">{m.label}: {m.display}</span>)}
        </div>
      ) : null}
      {String(player.scouting_production_snapshot || "").trim() ? (
        <div class="muted pre-wrap" style="margin-top:0.9rem;">{player.scouting_production_snapshot}</div>
      ) : <div class="muted pre-wrap">2025 production snapshot is updating; final context will appear after next refresh.</div>}
    </article>
    <article class="card">
      <h2 class="block-title">Historical Comp Panel</h2>
      <div class="muted pre-wrap">{compLine("Floor", player.historical_comp_floor, "Depth / rotation outcome")}</div>
      <div class="muted pre-wrap">{compLine("Median", player.historical_comp_median, "Starter outcome")}</div>
      <div class="muted pre-wrap">{compLine("Ceiling", player.historical_comp_ceiling, "Impact starter / all-pro ceiling")}</div>
      <div class="muted pre-wrap" style="margin-top:0.65rem;">Comp confidence: {player.comp_confidence || "-"}</div>
    </article>
    <article class="card">
      <h2 class="block-title">Role / Scheme Fit</h2>
      {roleChips.length ? (
        <div class="chip-row" style="margin-bottom:0.8rem;">
          {roleChips.map((chip: string, idx: number) => <span class={idx < 2 ? "chip good" : "chip info"}>{chip}</span>)}
        </div>
      ) : null}
      {positionLens && positionLens.rows.length ? (
        <div class="bar-metrics" style="margin-bottom:0.9rem;">
          {positionLens.rows.map((item: any) => (
            <div class="metric-row">
              <div class="metric-top"><span>{item.label}</span><strong>{Number(item.pct || 50).toFixed(0)}th pct</strong></div>
              <div class="meter"><div class="meter-fill" style={`width:${Number(item.pct || 50).toFixed(1)}%;background:#1f5ea8;`}></div></div>
              <div class="muted" style="margin-top:0.35rem;">{item.detail}</div>
            </div>
          ))}
        </div>
      ) : null}
      {roleParagraphs.length ? (
        <div class="summary-stack muted">
          {roleParagraphs.map((item: string) => <p class="block-copy">{item}</p>)}
        </div>
      ) : <div class="muted">Role and scheme projection is still calibrating.</div>}
    </article>
  </section>

  <section class="card back-card">
    <a href="/2026-nfl-draft-big-board" class="back-link">← Back to Big Board</a>
  </section>

</BaseLayout>

<style>
  .athletic-copy {
    margin-top: 0.4rem;
    line-height: 1.5;
  }
  .athletic-subgrid {
    display: grid;
    gap: 0.45rem;
    margin-top: 0.6rem;
  }
  .athletic-subrow {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.92rem;
    color: #4b5563;
  }
  .athletic-subrow strong {
    color: #0f172a;
    font-weight: 700;
  }
  .scout-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.65rem;
  }
  .scout-list li {
    line-height: 1.55;
  }
  .summary-stack {
    display: grid;
    gap: 0.75rem;
  }
  .summary-stack .block-copy,
  .report-summary {
    margin: 0;
    line-height: 1.65;
  }
</style>
