---
import BaseLayout from "../../layouts/BaseLayout.astro";
import board from "../../data/big_board_2026.json";

export function getStaticPaths() {
  return (board || []).map((p: any) => ({
    params: { slug: p.slug },
    props: { player: p }
  }));
}

const { player } = Astro.props;
const pageDescription = `${player.player_name} scouting report and model snapshot for the 2026 NFL Draft.`;
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: `${player.player_name} Scouting Report`,
  url: `https://scoutinggrade.com/players/${player.slug}`,
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
const ras = Number(player.combine_ras_official || 0) > 0 ? Number(player.combine_ras_official).toFixed(2) : (Number(player.ras_estimate || 0) > 0 ? `${Number(player.ras_estimate).toFixed(2)} (est.)` : "-");
const concernsText = String(player.scouting_primary_concerns || "");
const riskKeywords = [
  "medical",
  "character",
  "off-field",
  "discipline",
  "legal",
  "suspension",
  "injury concern",
  "concussion",
  "acl",
  "mcl",
  "achilles",
  "fracture",
];
const hasMedicalCharacterRisk = riskKeywords.some((k) => concernsText.toLowerCase().includes(k));
const productionPercentileValues = Object.values(player.production_percentiles || {}).map((v: any) => Number(v)).filter((n: number) => Number.isFinite(n));
const productionPct = productionPercentileValues.length ? (productionPercentileValues.reduce((a: number, b: number) => a + b, 0) / productionPercentileValues.length) : 50;
const rasRaw = Number(player.combine_ras_official || 0) > 0 ? Number(player.combine_ras_official || 0) : Number(player.ras_estimate || 0);
const athleticPct = Number.isFinite(rasRaw) && rasRaw > 0 ? Math.max(0, Math.min(100, ((rasRaw - 4) / 6) * 100)) : 50;
const traitRaw = Number(player.trait_score || 0);
const traitPct = Number.isFinite(traitRaw) && traitRaw > 0 ? Math.max(0, Math.min(100, ((traitRaw - 70) / 27) * 100)) : 50;
const marketRaw = Number(player.market_signal_pct || 50);
const marketPct = Number.isFinite(marketRaw) ? Math.max(0, Math.min(100, marketRaw)) : 50;
---
<BaseLayout title={`${player.player_name} | 2026 NFL Draft Scouting Report`} description={pageDescription} collectionSchema={collectionSchema}>
  <section class="hero hero--data">
    <h1>{player.player_name}</h1>
    <p>{player.position} · {player.school} · 2026 NFL Draft Prospect</p>
  </section>

  <section class="card summary-card">
    <div class="stat-grid">
      <div class="card"><strong>Model Rank</strong><div>{player.consensus_rank}</div></div>
      <div class="card"><strong>Model Grade</strong><div>{player.final_grade}</div></div>
      <div class="card"><strong>Round Range</strong><div>{player.round_value}</div></div>
      <div class="card"><strong>PFF Grade</strong><div>{Number(player.pff_grade || 0) > 0 ? Number(player.pff_grade).toFixed(1) : "-"}</div></div>
      <div class="card"><strong>Trait Score</strong><div>{Number(player.trait_score || 0) > 0 ? Number(player.trait_score).toFixed(2) : "-"}</div></div>
      <div class="card"><strong>RAS Score</strong><div>{ras}</div></div>
    </div>
    <div class="badge-row">
      <span class="badge">Top Driver: {String(player.top_rank_driver || "n/a").toUpperCase()} ({Number(player.top_rank_driver_delta) >= 0 ? "+" : ""}{player.top_rank_driver_delta})</span>
      {hasMedicalCharacterRisk ? <span class="badge warn">Risk Watch: medical/character item noted</span> : null}
    </div>
  </section>

  <section class="card detail-grid">
    <article class="card">
      <h2 class="block-title">Report Summary</h2>
      <p class="muted block-copy report-summary">{player.scouting_report_summary || "Summary pending."}</p>
    </article>
    <article class="card">
      <h2 class="block-title">Translation Snapshot</h2>
      <div class="bar-metrics">
        <div class="metric-row">
          <div class="metric-top"><span>Production Percentile</span><strong>{productionPct.toFixed(0)}th pct</strong></div>
          <div class="meter"><div class="meter-fill" style={`width:${productionPct.toFixed(1)}%;background:#0f7b6a;`}></div></div>
        </div>
        <div class="metric-row">
          <div class="metric-top"><span>Athletic Percentile</span><strong>{athleticPct.toFixed(0)}th pct</strong></div>
          <div class="meter"><div class="meter-fill" style={`width:${athleticPct.toFixed(1)}%;background:#425466;`}></div></div>
        </div>
        <div class="metric-row">
          <div class="metric-top"><span>Trait Percentile</span><strong>{traitPct.toFixed(0)}th pct</strong></div>
          <div class="meter"><div class="meter-fill" style={`width:${traitPct.toFixed(1)}%;background:#245ea8;`}></div></div>
        </div>
        <div class="metric-row">
          <div class="metric-top"><span>Market Signal</span><strong>{marketPct.toFixed(0)}th pct</strong></div>
          <div class="meter"><div class="meter-fill" style={`width:${marketPct.toFixed(1)}%;background:#0ea5e9;`}></div></div>
        </div>
      </div>
    </article>
    <article class="card">
      <h2 class="block-title">How He Wins</h2>
      <div class="muted pre-wrap">{player.scouting_why_he_wins || "Context pending."}</div>
    </article>
    <article class="card">
      <h2 class="block-title">Primary Concerns</h2>
      <div class="muted pre-wrap">{player.scouting_primary_concerns || "Concerns pending."}</div>
    </article>
    <article class="card">
      <h2 class="block-title">2025 Production Snapshot</h2>
      <div class="muted pre-wrap">{player.scouting_production_snapshot || "Production snapshot pending."}</div>
    </article>
    <article class="card">
      <h2 class="block-title">Role / Scheme Projection</h2>
      <div class="muted pre-wrap">{player.scouting_role_projection || "Projection pending."}</div>
    </article>
  </section>

  <section class="card back-card">
    <a href="/2026-nfl-draft-big-board" class="back-link">← Back to Big Board</a>
  </section>

</BaseLayout>
