---
import BaseLayout from "../layouts/BaseLayout.astro";
import meta from "../data/build_meta.json";
import weekly from "../data/weekly_changes_2026.json";

const pageDescription = "Weekly Scouting Grade updates for the 2026 NFL Draft board and mock drafts, including refresh timestamps and model coverage stats.";
const generatedAt = (meta as any)?.generated_at || "";
const rows = (meta as any)?.rows || {};
const summary = (weekly as any)?.summary || {};
const risers = (weekly as any)?.risers || [];
const fallers = (weekly as any)?.fallers || [];
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "2026 NFL Draft Weekly Updates",
  url: "https://scoutinggrade.com/2026-nfl-draft-weekly-updates",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
---
<BaseLayout title="2026 NFL Draft Weekly Updates | Scouting Grade" description={pageDescription} collectionSchema={collectionSchema}>
  <section class="hero">
    <h1>2026 NFL Draft Weekly Updates</h1>
    <p>Tracking each public refresh of the big board, mock drafts, and coverage depth.</p>
  </section>

  <section class="card page-intro">
    <h2 class="section-title">Refresh Tracker</h2>
    <p class="muted">
      Use this page to see when Scouting Grade last published an updated big board, mock draft, and site-data refresh. It is the quickest way
      to check whether the public board, team needs, and mock outputs are current.
    </p>
  </section>

  <section class="card updates-section">
    <h2 class="section-title">Latest Public Refresh</h2>
    <div class="mini-grid">
      <div class="card"><strong>Generated (UTC)</strong><div class="muted">{generatedAt || "Pending"}</div></div>
      <div class="card"><strong>Board Rows</strong><div class="muted">{rows.board ?? "-"}</div></div>
      <div class="card"><strong>Round 1 Picks</strong><div class="muted">{rows.round1 ?? "-"}</div></div>
      <div class="card"><strong>7-Round Picks</strong><div class="muted">{rows.round7 ?? "-"}</div></div>
    </div>
  </section>

  <section class="card single-note">
    <article class="card">
      <h3 class="subhead">What This Page Is For</h3>
      <p class="muted note-text">
        This is the public change-log surface for model refreshes. Use it to quickly verify when the latest board and mocks were published.
      </p>
    </article>
  </section>

  <section class="card updates-section">
    <h2 class="section-title">What Changed This Week</h2>
    <div class="mini-grid movers-grid">
      <div class="card"><strong>Total Movers</strong><div class="muted">{summary.movers_total ?? 0}</div></div>
      <div class="card"><strong>Risers</strong><div class="muted">{summary.risers_total ?? 0}</div></div>
      <div class="card"><strong>Fallers</strong><div class="muted">{summary.fallers_total ?? 0}</div></div>
    </div>

    <div class="lists-grid">
      <article class="card">
        <h3 class="subhead">Top Risers</h3>
        {risers.length === 0 ? (
          <p class="muted note-text">No rank movers logged in this cycle.</p>
        ) : (
          <ul class="change-list">
            {risers.map((r: any) => (
              <li>
                <strong>{r.player_name}</strong> ({r.position}) · +{r.rank_delta_prev_minus_curr}
                <span class="muted"> · {r.top_driver || "driver update"}</span>
              </li>
            ))}
          </ul>
        )}
      </article>

      <article class="card">
        <h3 class="subhead">Top Fallers</h3>
        {fallers.length === 0 ? (
          <p class="muted note-text">No downward movers logged in this cycle.</p>
        ) : (
          <ul class="change-list">
            {fallers.map((r: any) => (
              <li>
                <strong>{r.player_name}</strong> ({r.position}) · {r.rank_delta_prev_minus_curr}
                <span class="muted"> · {r.top_driver || "driver update"}</span>
              </li>
            ))}
          </ul>
        )}
      </article>
    </div>
  </section>

  <section class="card related-links">
    <h2 class="section-title">Related Draft Tools</h2>
    <div class="related-links-grid">
      <a class="related-link" href="/2026-nfl-draft-big-board">
        <strong>Big Board</strong>
        <span class="muted">See the current full ranking after each published refresh.</span>
      </a>
      <a class="related-link" href="/2026-nfl-mock-draft">
        <strong>Mock Draft Hub</strong>
        <span class="muted">Track how board movement affects round-one and seven-round projections.</span>
      </a>
      <a class="related-link" href="/nfl-team-needs-2026">
        <strong>Team Needs</strong>
        <span class="muted">Review how roster pressure shifts alongside each public update cycle.</span>
      </a>
    </div>
  </section>

  <style>
    .updates-section {
      margin-top: 1rem;
    }
    .updates-section:first-of-type {
      margin-top: 0;
      margin-bottom: 1rem;
    }
    .mini-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 0.55rem;
    }
    .single-note {
      display: grid;
      gap: 0.8rem;
      margin-bottom: 1rem;
    }
    .subhead {
      margin: 0 0 0.45rem;
      font-size: 1.02rem;
    }
    .note-text {
      margin: 0.2rem 0;
      line-height: 1.55;
    }
    .movers-grid {
      margin-bottom: 0.7rem;
    }
    .lists-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 0.7rem;
    }
    .change-list {
      margin: 0.2rem 0;
      padding-left: 1rem;
      line-height: 1.55;
    }
    .change-list li {
      margin: 0.2rem 0;
    }
  </style>
</BaseLayout>
