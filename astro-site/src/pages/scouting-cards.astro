---
import BaseLayout from "../layouts/BaseLayout.astro";
import board from "../data/big_board_2026.json";

const pool = (board || []).slice(0, 264);
const pageDescription = "Scouting card snapshots for 2026 NFL Draft prospects with summary, wins, concerns, production, and role projection.";
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "2026 NFL Scouting Cards",
  url: "https://scoutinggrade.com/scouting-cards",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
---
<BaseLayout title="2026 NFL Scouting Cards | Scouting Grade" description={pageDescription} collectionSchema={collectionSchema}>
  <section class="hero hero--data">
    <h1>2026 NFL Scouting Cards</h1>
    <p>Search and review concise scouting snapshots for this class.</p>
  </section>

  <section class="card search-card">
    <label for="playerSearch" class="muted search-label">Search by player, school, or position</label>
    <input id="playerSearch" type="search" placeholder="Start typing a name..." class="control search-control" />
    <div class="list-wrap">
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Player</th>
            <th>Pos</th>
            <th>School</th>
            <th>Grade</th>
          </tr>
        </thead>
        <tbody id="playerRows"></tbody>
      </table>
    </div>
  </section>

  <section class="card" id="cardDetails">
    <h2 id="playerTitle" class="player-title">Select a player</h2>
    <div id="playerMeta" class="muted player-meta"></div>
    <p class="player-link-wrap"><a id="playerLink" href="/2026-nfl-draft-big-board" class="player-link">Open full player page →</a></p>
    <div class="stats-grid">
      <div class="card"><strong>Model Rank</strong><div id="dRank">-</div></div>
      <div class="card"><strong>Model Grade</strong><div id="dGrade">-</div></div>
      <div class="card"><strong>PFF Grade</strong><div id="dPff">-</div></div>
      <div class="card"><strong>RAS Score</strong><div id="dRas">-</div></div>
    </div>
    <div class="detail-grid">
      <article class="card"><strong>Report Summary</strong><div id="dSummary" class="muted detail-text report-summary"></div></article>
      <article class="card"><strong>How He Wins</strong><div id="dWins" class="muted detail-text pre-wrap"></div></article>
      <article class="card"><strong>Primary Concerns</strong><div id="dConcerns" class="muted detail-text pre-wrap"></div></article>
      <article class="card"><strong>2025 Production Snapshot</strong><div id="dProd" class="muted detail-text pre-wrap"></div></article>
      <article class="card"><strong>Role / Scheme Projection</strong><div id="dRole" class="muted detail-text pre-wrap"></div></article>
    </div>
  </section>

  <script define:vars={{ pool }}>
    const rowsRoot = document.getElementById("playerRows");
    const search = document.getElementById("playerSearch");
    const byUid = {};
    pool.forEach((p) => { byUid[p.player_uid] = p; });

    const fmt = (v) => {
      if (v === null || v === undefined || v === "") return "-";
      return String(v);
    };

    const rasScore = (p) => {
      const official = Number(p.combine_ras_official || 0);
      if (official > 0) return official.toFixed(2);
      const est = Number(p.ras_estimate || 0);
      if (est > 0) return est.toFixed(2);
      return "-";
    };

    const renderList = () => {
      const q = (search?.value || "").toLowerCase().trim();
      const filtered = pool.filter((p) => {
        if (!q) return true;
        return (
          (p.player_name || "").toLowerCase().includes(q) ||
          (p.school || "").toLowerCase().includes(q) ||
          (p.position || "").toLowerCase().includes(q)
        );
      });
      rowsRoot.innerHTML = "";
      filtered.slice(0, 200).forEach((p) => {
        const tr = document.createElement("tr");
        tr.style.cursor = "pointer";
        tr.innerHTML = `
          <td>${fmt(p.consensus_rank)}</td>
          <td>${fmt(p.player_name)}</td>
          <td><span class="badge">${fmt(p.position)}</span></td>
          <td>${fmt(p.school)}</td>
          <td>${fmt(p.final_grade)}</td>
        `;
        tr.addEventListener("click", () => showCard(p.player_uid));
        rowsRoot.appendChild(tr);
      });
    };

    const setText = (id, value) => {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    };

    const showCard = (uid) => {
      const p = byUid[uid];
      if (!p) return;

      setText("playerTitle", fmt(p.player_name));
      setText("playerMeta", `${fmt(p.school)} · ${fmt(p.position)} · ${fmt(p.round_value)}`);
      const link = document.getElementById("playerLink");
      if (link && p.slug) link.href = `/players/${p.slug}`;
      setText("dRank", fmt(p.consensus_rank));
      setText("dGrade", fmt(p.final_grade));
      setText("dPff", Number(p.pff_grade || 0) > 0 ? Number(p.pff_grade).toFixed(1) : "-");
      setText("dRas", rasScore(p));
      setText("dSummary", fmt(p.scouting_report_summary));
      setText("dWins", fmt(p.scouting_why_he_wins));
      setText("dConcerns", fmt(p.scouting_primary_concerns));
      setText("dProd", fmt(p.scouting_production_snapshot));
      setText("dRole", fmt(p.scouting_role_projection));
    };

    search?.addEventListener("input", renderList);
    renderList();
    if (pool.length) showCard(pool[0].player_uid);
  </script>

</BaseLayout>
