---
import BaseLayout from "../layouts/BaseLayout.astro";
import board from "../data/big_board_2026.json";

const pool = (board || []).slice(0, 264);
const pageDescription = "Scouting card snapshots for 2026 NFL Draft prospects with summary, wins, concerns, production, and role projection.";
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "2026 NFL Scouting Cards",
  url: "https://scoutinggrade.com/scouting-cards",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
---
<BaseLayout title="2026 NFL Scouting Cards | Scouting Grade" description={pageDescription} collectionSchema={collectionSchema}>
  <section class="hero hero--data">
    <h1>2026 NFL Scouting Cards</h1>
    <p>Search and review concise scouting snapshots for this class.</p>
  </section>

  <section class="card search-card">
    <label for="playerSearch" class="muted search-label">Search by player, school, or position</label>
    <input id="playerSearch" type="search" placeholder="Start typing a name..." class="control search-control" />
    <div class="list-wrap">
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Player</th>
            <th>Pos</th>
            <th>School</th>
            <th>Grade</th>
          </tr>
        </thead>
        <tbody id="playerRows"></tbody>
      </table>
    </div>
  </section>

  <section class="card" id="cardDetails">
    <h2 id="playerTitle" class="player-title">Select a player</h2>
    <div id="playerMeta" class="muted player-meta"></div>
    <p class="player-link-wrap"><a id="playerLink" href="/2026-nfl-draft-big-board" class="player-link">Open full player page →</a></p>
    <div class="stats-grid">
      <div class="card"><strong>Model Rank</strong><div id="dRank">-</div></div>
      <div class="card"><strong>Model Grade</strong><div id="dGrade">-</div></div>
      <div class="card"><strong>PFF Grade</strong><div id="dPff">-</div></div>
      <div class="card"><strong>RAS Score</strong><div id="dRas">-</div></div>
    </div>
    <div class="detail-grid">
      <article class="card"><strong>Report Summary</strong><div id="dSummary" class="muted detail-text report-summary"></div></article>
      <article class="card"><strong>How He Wins</strong><div id="dWins" class="muted detail-text"></div></article>
      <article class="card"><strong>Primary Concerns</strong><div id="dConcerns" class="muted detail-text"></div></article>
      <article class="card"><strong>Film Notes</strong><div id="dFilm" class="muted detail-text"></div></article>
      <article class="card"><strong>2025 Production Snapshot</strong><div id="dProd" class="muted detail-text"></div></article>
      <article class="card"><strong>Role / Scheme Fit</strong><div id="dRole" class="muted detail-text"></div></article>
    </div>
  </section>

  <script define:vars={{ pool }}>
    const rowsRoot = document.getElementById("playerRows");
    const search = document.getElementById("playerSearch");
    const byUid = {};
    pool.forEach((p) => { byUid[p.player_uid] = p; });

    const fmt = (v) => {
      if (v === null || v === undefined || v === "") return "-";
      return String(v);
    };

    const rasScore = (p) => {
      const official = Number(p.combine_ras_official || 0);
      if (official > 0) return official.toFixed(2);
      const est = Number(p.ras_estimate || 0);
      if (est > 0) return est.toFixed(2);
      return "-";
    };

    const renderList = () => {
      const q = (search?.value || "").toLowerCase().trim();
      const filtered = pool.filter((p) => {
        if (!q) return true;
        return (
          (p.player_name || "").toLowerCase().includes(q) ||
          (p.school || "").toLowerCase().includes(q) ||
          (p.position || "").toLowerCase().includes(q)
        );
      });
      rowsRoot.innerHTML = "";
      filtered.slice(0, 200).forEach((p) => {
        const tr = document.createElement("tr");
        tr.style.cursor = "pointer";
        tr.innerHTML = `
          <td>${fmt(p.consensus_rank)}</td>
          <td>${fmt(p.player_name)}</td>
          <td><span class="badge">${fmt(p.position)}</span></td>
          <td>${fmt(p.school)}</td>
          <td>${fmt(p.final_grade)}</td>
        `;
        tr.addEventListener("click", () => showCard(p.player_uid));
        rowsRoot.appendChild(tr);
      });
    };

    const setText = (id, value) => {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    };

    const toBullets = (value) =>
      String(value || "")
        .replace(/\\n/g, "\n")
        .split(/\n+/)
        .map((line) => String(line || "").trim())
        .filter(Boolean)
        .map((line) => line.replace(/^(?:[-*•]\s*|\d+\.\s*)/, "").trim());

    const toParagraphs = (value) =>
      String(value || "")
        .split(/\n{2,}/)
        .map((part) => String(part || "").trim())
        .filter(Boolean);

    const escapeHtml = (value) =>
      String(value || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const renderParagraphStack = (id, value, fallback) => {
      const el = document.getElementById(id);
      if (!el) return;
      const parts = toParagraphs(value);
      if (!parts.length) {
        el.innerHTML = `<p class="block-copy">${escapeHtml(fallback)}</p>`;
        return;
      }
      el.innerHTML = `<div class="summary-stack">${parts.map((part) => `<p class="block-copy">${escapeHtml(part)}</p>`).join("")}</div>`;
    };

    const renderBulletList = (id, value, fallback) => {
      const el = document.getElementById(id);
      if (!el) return;
      const items = toBullets(value);
      if (!items.length) {
        el.innerHTML = `<p class="block-copy">${escapeHtml(fallback)}</p>`;
        return;
      }
      el.innerHTML = `<ul class="scout-list">${items.map((item) => `<li>${escapeHtml(item)}</li>`).join("")}</ul>`;
    };

    const renderProduction = (id, player) => {
      const el = document.getElementById(id);
      if (!el) return;
      const advancedRows = Array.isArray(player.advanced_metric_cards) ? player.advanced_metric_cards : [];
      const countRows = Array.isArray(player.counting_stat_chips) ? player.counting_stat_chips : [];
      const snapshotText = String(player.scouting_production_snapshot || "").trim();
      const blocks = [];
      if (advancedRows.length) {
        blocks.push(`
          <div class="bar-metrics">
            ${advancedRows.map((m) => `
              <div class="metric-row">
                <div class="metric-top"><span>${escapeHtml(m.label)}</span><strong>${escapeHtml(m.display)} · ${Number(m.pct || 50).toFixed(0)}th pct</strong></div>
                <div class="meter"><div class="meter-fill" style="width:${Number(m.pct || 50).toFixed(1)}%;background:#0f7b6a;"></div></div>
              </div>
            `).join("")}
          </div>
        `);
      }
      if (countRows.length) {
        blocks.push(`
          <div class="chip-row card-chip-row">
            ${countRows.map((m) => `<span class="chip info">${escapeHtml(m.label)}: ${escapeHtml(m.display)}</span>`).join("")}
          </div>
        `);
      }
      if (snapshotText) {
        blocks.push(`<p class="block-copy">${escapeHtml(snapshotText)}</p>`);
      }
      if (!blocks.length) {
        blocks.push(`<p class="block-copy">No production snapshot available yet.</p>`);
      }
      el.innerHTML = blocks.join("");
    };

    const renderFilmNotes = (id, value) => {
      const el = document.getElementById(id);
      if (!el) return;
      const items = toBullets(value);
      if (!items.length) {
        el.innerHTML = `<p class="block-copy">Film notes will appear here as scouting updates are published.</p>`;
        return;
      }
      el.innerHTML = `<ul class="scout-list">${items.map((item) => `<li>${escapeHtml(item)}</li>`).join("")}</ul>`;
    };

    const renderRoleFit = (id, player) => {
      const el = document.getElementById(id);
      if (!el) return;
      const positionLens = player && typeof player.position_lens === "object" && Array.isArray(player.position_lens.rows)
        ? player.position_lens
        : null;
      const roleParagraphs = toParagraphs(String(player.scouting_role_projection || ""));
      const roleChips = [
        String(player.best_role || "").trim(),
        String(player.best_scheme_fit || "").trim(),
        ...((positionLens && Array.isArray(positionLens.tags)) ? positionLens.tags : []),
      ].filter(Boolean);
      const blocks = [];
      if (roleChips.length) {
        blocks.push(`
          <div class="chip-row card-chip-row">
            ${roleChips.map((chip, idx) => `<span class="${idx < 2 ? "chip good" : "chip info"}">${escapeHtml(chip)}</span>`).join("")}
          </div>
        `);
      }
      if (positionLens && positionLens.rows.length) {
        blocks.push(`
          <div class="bar-metrics">
            ${positionLens.rows.map((item) => `
              <div class="metric-row">
                <div class="metric-top"><span>${escapeHtml(item.label)}</span><strong>${Number(item.pct || 50).toFixed(0)}th pct</strong></div>
                <div class="meter"><div class="meter-fill" style="width:${Number(item.pct || 50).toFixed(1)}%;background:#1f5ea8;"></div></div>
                <div class="muted lens-detail">${escapeHtml(item.detail || "")}</div>
              </div>
            `).join("")}
          </div>
        `);
      }
      if (roleParagraphs.length) {
        blocks.push(`<div class="summary-stack">${roleParagraphs.map((part) => `<p class="block-copy">${escapeHtml(part)}</p>`).join("")}</div>`);
      } else {
        blocks.push(`<p class="block-copy">Role and scheme projection is still calibrating.</p>`);
      }
      el.innerHTML = blocks.join("");
    };

    const showCard = (uid) => {
      const p = byUid[uid];
      if (!p) return;

      setText("playerTitle", fmt(p.player_name));
      setText("playerMeta", `${fmt(p.school)} · ${fmt(p.position)} · ${fmt(p.round_value)}`);
      const link = document.getElementById("playerLink");
      if (link && p.slug) link.href = `/players/${p.slug}`;
      setText("dRank", fmt(p.consensus_rank));
      setText("dGrade", fmt(p.final_grade));
      setText("dPff", Number(p.pff_grade || 0) > 0 ? Number(p.pff_grade).toFixed(1) : "-");
      setText("dRas", rasScore(p));
      renderParagraphStack("dSummary", p.scouting_report_summary, "No scouting summary available yet.");
      renderBulletList("dWins", p.scouting_why_he_wins, "How he wins assessment updates as scouting notes refresh.");
      renderBulletList("dConcerns", p.scouting_primary_concerns, "No major concerns flagged in the current profile.");
      renderFilmNotes("dFilm", p.scouting_film_notes);
      renderProduction("dProd", p);
      renderRoleFit("dRole", p);
    };

    search?.addEventListener("input", renderList);
    renderList();
    if (pool.length) showCard(pool[0].player_uid);
  </script>

</BaseLayout>

<style>
  .scout-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.65rem;
  }
  .summary-stack {
    display: grid;
    gap: 0.75rem;
  }
  .block-copy {
    margin: 0;
    line-height: 1.65;
  }
  .card-chip-row {
    margin-bottom: 0.8rem;
  }
  .lens-detail {
    margin-top: 0.35rem;
  }
</style>
