---
import BaseLayout from "../layouts/BaseLayout.astro";
import board from "../data/big_board_2026.json";
const pageDescription = "2026 NFL Draft big board with updated rankings, grades, round value, and scouting context for top prospects.";
const preferredPositionOrder = ["QB", "RB", "WR", "TE", "OT", "IOL", "DT", "EDGE", "LB", "CB", "S"];
const boardPositions = Array.from(new Set((board || []).map((r: any) => r.position).filter(Boolean)));
const positions = [
  ...preferredPositionOrder.filter((p) => boardPositions.includes(p)),
  ...boardPositions.filter((p) => !preferredPositionOrder.includes(p)).sort(),
];
const roundBands = Array.from(new Set((board || []).map((r: any) => r.round_value).filter(Boolean))).sort();
const schools = Array.from(new Set((board || []).map((r: any) => r.school).filter(Boolean))).sort();
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "2026 NFL Draft Big Board",
  url: "https://scoutinggrade.com/2026-nfl-draft-big-board",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
const rankList = (board || []).slice(0, 100).map((r: any, idx: number) => ({
  "@type": "ListItem",
  position: idx + 1,
  name: r.player_name,
  url: `https://scoutinggrade.com/players/${r.slug}`,
}));
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "2026 NFL Draft Big Board Rankings",
  itemListOrder: "https://schema.org/ItemListOrderAscending",
  numberOfItems: rankList.length,
  itemListElement: rankList,
};
---
<BaseLayout
  title="2026 NFL Draft Big Board Rankings | Scouting Grade"
  description={pageDescription}
  keywords={["2026 nfl draft big board", "nfl draft rankings", "nfl prospects 2026", "scouting grade"]}
  collectionSchema={collectionSchema}
  extraSchemas={[itemListSchema]}
>
  <section class="hero hero--data bigboard-hero">
    <h1>2026 NFL Draft Big Board</h1>
    <p>Live ranked board with scouting context, team-era lens, and weekly refreshes.</p>
  </section>

  <section class="card bigboard-intro">
    <h2>How To Use This Board</h2>
    <p class="muted">
      Think of <strong>Grade</strong> as player quality and <strong>Round</strong> as expected draft range.
    </p>
    <p class="muted">
      Use search to quickly find a player, school, or position. The table updates instantly.
    </p>
  </section>

  <section class="card bigboard-card">
    <div class="filters-grid">
      <input
        id="search"
        type="search"
        placeholder="Search player, school, or position..."
        class="control search-control"
      />
      <select id="positionFilter" class="control">
        <option value="">All Positions</option>
        {positions.map((p) => <option value={p}>{p}</option>)}
      </select>
      <select id="roundFilter" class="control">
        <option value="">All Round Bands</option>
        {roundBands.map((b) => <option value={b}>{b}</option>)}
      </select>
      <select id="schoolFilter" class="control">
        <option value="">All Schools</option>
        {schools.map((s) => <option value={s}>{s}</option>)}
      </select>
      <select id="sortBy" class="control">
        <option value="rank_asc">Sort: Rank (best first)</option>
        <option value="grade_desc">Sort: Grade (high to low)</option>
        <option value="consensus_asc">Sort: Consensus Mean (best first)</option>
        <option value="name_asc">Sort: Name (A-Z)</option>
      </select>
    </div>

    <div class="result-bar">
      <span id="resultCount" class="muted">Showing {board.length} of {board.length} prospects.</span>
      <button id="resetFilters" type="button" class="reset-btn">Reset Filters</button>
    </div>

    <div class="table-wrap">
      <table id="boardTable">
        <thead>
          <tr>
            <th>Rank</th>
            <th>Player</th>
            <th>Pos</th>
            <th>School</th>
            <th>Grade</th>
            <th>Round</th>
            <th>Consensus Mean</th>
            <th>Why Moved</th>
          </tr>
        </thead>
        <tbody>
          {board.map((r: any) => (
            <tr
              data-search={`${r.player_name} ${r.position} ${r.school}`.toLowerCase()}
              data-rank={r.consensus_rank}
              data-grade={r.final_grade}
              data-consensus={r.consensus_board_mean_rank || 9999}
              data-position={r.position || ""}
              data-round={r.round_value || ""}
              data-school={r.school || ""}
              data-name={r.player_name || ""}
            >
              <td>{r.consensus_rank}</td>
              <td><a href={`/players/${r.slug}`} class="player-link">{r.player_name}</a></td>
              <td><span class="badge">{r.position}</span></td>
              <td>{r.school}</td>
              <td>{r.final_grade}</td>
              <td>{r.round_value}</td>
              <td>{r.consensus_board_mean_rank || ""}</td>
              <td>
                <span class="driver-badge {Number(r.top_rank_driver_delta) >= 0 ? 'up' : 'down'}">
                  {String(r.top_rank_driver || "n/a").toUpperCase()} {Number(r.top_rank_driver_delta) >= 0 ? "+" : ""}{r.top_rank_driver_delta}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <script>
    const input = document.getElementById("search");
    const positionFilter = document.getElementById("positionFilter");
    const roundFilter = document.getElementById("roundFilter");
    const schoolFilter = document.getElementById("schoolFilter");
    const sortBy = document.getElementById("sortBy");
    const resetBtn = document.getElementById("resetFilters");
    const resultCount = document.getElementById("resultCount");
    const tbody = document.querySelector("#boardTable tbody");
    const rows = Array.from(document.querySelectorAll("#boardTable tbody tr"));

    const num = (value, fallback = 0) => {
      const n = Number(value);
      return Number.isFinite(n) ? n : fallback;
    };

    const applyFiltersAndSort = () => {
      const q = (input?.value || "").toLowerCase().trim();
      const pos = positionFilter?.value || "";
      const rnd = roundFilter?.value || "";
      const school = schoolFilter?.value || "";
      const sort = sortBy?.value || "rank_asc";

      const filtered = rows.filter((row) => {
        const hay = row.getAttribute("data-search") || "";
        const rowPos = row.getAttribute("data-position") || "";
        const rowRound = row.getAttribute("data-round") || "";
        const rowSchool = row.getAttribute("data-school") || "";
        return (
          (!q || hay.includes(q)) &&
          (!pos || rowPos === pos) &&
          (!rnd || rowRound === rnd) &&
          (!school || rowSchool === school)
        );
      });

      filtered.sort((a, b) => {
        if (sort === "grade_desc") return num(b.getAttribute("data-grade"), -9999) - num(a.getAttribute("data-grade"), -9999);
        if (sort === "consensus_asc") return num(a.getAttribute("data-consensus"), 9999) - num(b.getAttribute("data-consensus"), 9999);
        if (sort === "name_asc") return (a.getAttribute("data-name") || "").localeCompare(b.getAttribute("data-name") || "");
        return num(a.getAttribute("data-rank"), 9999) - num(b.getAttribute("data-rank"), 9999);
      });

      rows.forEach((row) => row.style.display = "none");
      filtered.forEach((row) => {
        row.style.display = "";
        tbody?.appendChild(row);
      });

      if (resultCount) resultCount.textContent = `Showing ${filtered.length} of ${rows.length} prospects.`;
    };

    [input, positionFilter, roundFilter, schoolFilter, sortBy].forEach((el) => {
      el?.addEventListener("input", applyFiltersAndSort);
      el?.addEventListener("change", applyFiltersAndSort);
    });

    resetBtn?.addEventListener("click", () => {
      if (input) input.value = "";
      if (positionFilter) positionFilter.value = "";
      if (roundFilter) roundFilter.value = "";
      if (schoolFilter) schoolFilter.value = "";
      if (sortBy) sortBy.value = "rank_asc";
      applyFiltersAndSort();
    });

    applyFiltersAndSort();
  </script>
</BaseLayout>
