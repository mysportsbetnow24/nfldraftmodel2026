---
import BaseLayout from "../layouts/BaseLayout.astro";
import board from "../data/big_board_2026.json";
const pageDescription = "Live 2026 NFL Draft big board from the Scouting Grade model with ranks, grades, and projection context.";
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "2026 NFL Draft Big Board",
  url: "https://scoutinggrade.com/2026-nfl-draft-big-board",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
---
<BaseLayout title="2026 NFL Draft Big Board | Scouting Grade" description={pageDescription} collectionSchema={collectionSchema}>
  <section class="hero">
    <h1>2026 NFL Draft Big Board</h1>
    <p>Model-ranked prospects using production, athletic, context, and consensus signals with guardrails.</p>
  </section>

  <section class="card" style="margin-bottom:1rem;">
    <h2 style="margin:0 0 .45rem;">How To Use This Board</h2>
    <p class="muted" style="margin:.2rem 0 .35rem;">
      This board ranks 2026 prospects by the current model output, then groups them with a round-value projection.
      Think of <strong>Grade</strong> as player quality and <strong>Round</strong> as expected draft range.
    </p>
    <p class="muted" style="margin:.2rem 0 0;">
      Use search to quickly find a player, school, or position. The table updates instantly.
    </p>
  </section>

  <section class="card">
    <div style="display:flex;gap:.65rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem;">
      <input
        id="search"
        type="search"
        placeholder="Search player, school, or position..."
        style="padding:.62rem .7rem;border:1px solid var(--line);border-radius:10px;min-width:300px;max-width:520px;width:100%;"
      />
      <span class="muted">Total Prospects: {board.length}</span>
    </div>
    <div style="overflow:auto;border:1px solid var(--line);border-radius:12px;">
      <table id="boardTable">
        <thead>
          <tr>
            <th>Rank</th>
            <th>Player</th>
            <th>Pos</th>
            <th>School</th>
            <th>Grade</th>
            <th>Round</th>
            <th>Consensus Mean</th>
          </tr>
        </thead>
        <tbody>
          {board.map((r: any) => (
            <tr data-search={`${r.player_name} ${r.position} ${r.school}`.toLowerCase()}>
              <td>{r.consensus_rank}</td>
              <td>{r.player_name}</td>
              <td><span class="badge">{r.position}</span></td>
              <td>{r.school}</td>
              <td>{r.final_grade}</td>
              <td>{r.round_value}</td>
              <td>{r.consensus_board_mean_rank || ""}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <style>
    #boardTable thead th {
      position: sticky;
      top: 0;
      background: #f9fbfd;
      z-index: 1;
    }
    #boardTable tbody tr:nth-child(even) {
      background: #fcfdff;
    }
    #boardTable tbody tr:hover {
      background: #f2f7fc;
    }
  </style>

  <script>
    const input = document.getElementById("search");
    const rows = Array.from(document.querySelectorAll("#boardTable tbody tr"));
    if (input) {
      input.addEventListener("input", (e) => {
        const q = (e.target?.value || "").toLowerCase().trim();
        rows.forEach((row) => {
          const hay = row.getAttribute("data-search") || "";
          row.style.display = q && !hay.includes(q) ? "none" : "";
        });
      });
    }
  </script>
</BaseLayout>
