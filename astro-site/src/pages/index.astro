---
import BaseLayout from "../layouts/BaseLayout.astro";
import board from "../data/big_board_2026.json";
import meta from "../data/build_meta.json";

const top = (board || []).slice(0, 25);
const pageDescription = "NFL Draft Hub 2026 featuring the latest big board rankings, mock drafts, team needs, transactions, and scouting cards.";
const featuredDraftTools = [
  { href: "/2026-nfl-draft-big-board", label: "Big Board", detail: "Full class ranking with grades and role context." },
  { href: "/2026-nfl-mock-draft", label: "Mock Draft Hub", detail: "Jump between round-one and seven-round projections." },
  { href: "/nfl-team-needs-2026", label: "Team Needs", detail: "Scan roster pressure, contract watch, and priority needs." },
  { href: "/2026-nfl-player-comparison", label: "Player Compare", detail: "Stack prospects by profile, fit, and comps." },
];
const featuredProspects = [
  { href: "/players/fernando-mendoza", label: "Fernando Mendoza", detail: "QB1 on the current board." },
  { href: "/players/jeremiyah-love", label: "Jeremiyah Love", detail: "Complete back with rare ceiling traits." },
  { href: "/players/jordyn-tyson", label: "Jordyn Tyson", detail: "Route-craft volume earner with Round 1 juice." },
  { href: "/players/sonny-styles", label: "Sonny Styles", detail: "Former safety athlete with LB range and power." },
  { href: "/players/caleb-downs", label: "Caleb Downs", detail: "Coverage eraser with elite back-end versatility." },
  { href: "/players/arvell-reese", label: "Arvell Reese", detail: "Hybrid pressure linebacker with edge traits." },
];
const featuredTeams = [
  { href: "/nfl-team-needs-2026/las-vegas-raiders", label: "Raiders Team Needs", detail: "Check the current QB and front-seven pressure points." },
  { href: "/nfl-team-needs-2026/baltimore-ravens", label: "Ravens Team Needs", detail: "Monitor line depth, contracts, and 2026 priorities." },
  { href: "/nfl-team-needs-2026/green-bay-packers", label: "Packers Team Needs", detail: "Review OL, front-seven, and roster pressure spots." },
  { href: "/nfl-team-needs-2026/kansas-city-chiefs", label: "Chiefs Team Needs", detail: "Track expiring contributors and defensive pressure points." },
  { href: "/nfl-team-needs-2026/new-england-patriots", label: "Patriots Team Needs", detail: "See how roster build shapes the top of the mock." },
  { href: "/nfl-team-needs-2026/dallas-cowboys", label: "Cowboys Team Needs", detail: "Cross-check roster stress against the current board." },
];
const featuredReports = [
  {
    href: "/players/fernando-mendoza",
    player: "Fernando Mendoza",
    meta: "QB • Indiana",
    detail: "Top-of-board quarterback with size, poise, and enough off-platform creation to stress the full field.",
    cta: "Open Scouting Report",
    accent: "Board QB1",
    image: "/features/fernando-mendoza.jpg",
    hero: true,
  },
  {
    href: "/players/sonny-styles",
    player: "Sonny Styles",
    meta: "LB • Ohio State",
    detail: "Former safety athlete with big-space range, pressure utility, and true defensive chess-piece upside.",
    cta: "View Sonny Styles",
    accent: "Top-5 Athlete",
    image: "/features/sonny-styles.jpg",
  },
  {
    href: "/players/jordyn-tyson",
    player: "Jordyn Tyson",
    meta: "WR • Arizona State",
    detail: "Route-craft volume earner whose leverage control and late-hands finishing keep pushing him into Round 1 territory.",
    cta: "View Jordyn Tyson",
    accent: "Round 1 WR",
    image: "/features/jordyn-tyson.jpg",
  },
];
const landingSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "NFL Draft Hub 2026",
  url: "https://scoutinggrade.com/",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com",
  },
};
---
<BaseLayout
  title="NFL Draft Hub 2026 | Big Board, Mock Drafts, Team Needs"
  description={pageDescription}
  keywords={["nfl draft hub 2026", "2026 nfl draft", "nfl draft big board", "nfl mock draft", "team needs 2026"]}
  collectionSchema={landingSchema}
  shellClass="home-shell-wide"
>
  <section class="hero hero--data">
    <div class="home-hero-brand">
      <img src="/brand/sg-mark-yardline.svg" alt="Scouting Grade logo" class="home-hero-mark" />
      <div class="home-hero-copy">
        <h1>NFL Draft Hub 2026</h1>
      </div>
    </div>
    <p>Model-first big board, mock drafts, and scouting cards.</p>
  </section>

  <section class="home-shell">
    <aside class="home-rail">
      <section class="card home-rail-card">
        <h2 class="section-title">Featured Draft Tools</h2>
        <div class="home-rail-list">
          {featuredDraftTools.map((item) => (
            <a class="home-rail-link" href={item.href}>
              <strong>{item.label}</strong>
              <span class="muted">{item.detail}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="card home-rail-card">
        <h2 class="section-title">Featured Team Pages</h2>
        <div class="home-rail-list">
          {featuredTeams.map((item) => (
            <a class="home-rail-link" href={item.href}>
              <strong>{item.label}</strong>
              <span class="muted">{item.detail}</span>
            </a>
          ))}
        </div>
      </section>
    </aside>

    <div class="home-main">
      <section class="card featured-reports-card">
        <div class="result-bar">
          <h2 class="section-title">Featured Scouting Reports</h2>
          <a class="reset-btn" href="/scouting-cards">Browse All Cards</a>
        </div>
        <div class="featured-reports-grid">
          {featuredReports.map((item) => (
            <a class:list={["featured-report", item.hero && "featured-report--hero"]} href={item.href}>
              {item.image && (
                <div class="featured-report__media">
                  <img src={item.image} alt={`${item.player} scouting report`} loading="lazy" />
                  <span class="featured-report__badge">{item.accent}</span>
                  <span class="featured-report__mark">
                    <img src="/brand/sg-mark-yardline.svg" alt="" aria-hidden="true" />
                  </span>
                </div>
              )}
              <div class="featured-report__body">
                {!item.image && <span class="featured-report__badge featured-report__badge--inline">{item.accent}</span>}
                <strong>{item.player}</strong>
                <span class="featured-report__meta">{item.meta}</span>
                <span class="muted">{item.detail}</span>
                <span class="featured-report__cta">{item.cta}</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="card">
        <div class="result-bar">
          <h2 class="section-title">Top Board Snapshot</h2>
          <span class="muted">Generated: {meta.generated_at || "Auto refreshed after latest pull"}</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Rank</th>
                <th>Player</th>
                <th>Pos</th>
                <th>School</th>
                <th>Grade</th>
                <th>Round</th>
              </tr>
            </thead>
            <tbody>
              {top.map((r: any) => (
                <tr>
                  <td>{r.consensus_rank}</td>
                  <td><a href={`/players/${r.slug}`} class="player-link">{r.player_name}</a></td>
                  <td><span class="badge">{r.position}</span></td>
                  <td>{r.school}</td>
                  <td>{r.final_grade}</td>
                  <td>{r.round_value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <aside class="home-rail">
      <section class="card home-rail-card">
        <h2 class="section-title">Featured Prospects</h2>
        <div class="home-rail-list">
          {featuredProspects.map((item) => (
            <a class="home-rail-link" href={item.href}>
              <strong>{item.label}</strong>
              <span class="muted">{item.detail}</span>
            </a>
          ))}
        </div>
      </section>
    </aside>
  </section>

</BaseLayout>

<style>
  .home-shell {
    display: grid;
    grid-template-columns: minmax(200px, 240px) minmax(0, 1.35fr) minmax(200px, 240px);
    gap: 1rem;
    align-items: start;
  }

  .home-main {
    display: grid;
    gap: 1rem;
  }

  .home-rail {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 1rem;
  }

  .home-rail-card {
    background: linear-gradient(180deg, rgba(245, 250, 253, 0.98), rgba(235, 244, 249, 0.92));
  }

  .home-rail-list {
    display: grid;
    gap: 0.6rem;
  }

  .home-rail-link {
    display: grid;
    gap: 0.18rem;
    padding: 0.85rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.76);
    transition: border-color 0.14s ease, box-shadow 0.14s ease, transform 0.12s ease;
  }

  .home-rail-link strong {
    color: var(--brand);
  }

  .home-rail-link:hover {
    transform: translateY(-1px);
    border-color: #8fb2d8;
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.08);
  }

  .home-hero-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .home-hero-mark {
    width: 64px;
    height: 64px;
    flex: 0 0 auto;
    filter: drop-shadow(0 4px 18px rgba(15, 23, 42, 0.18));
  }

  .home-hero-copy {
    display: grid;
    gap: 0.1rem;
  }

  .home-hero-copy h1 {
    margin: 0;
  }

  .featured-reports-card {
    display: grid;
    gap: 0.9rem;
  }

  .featured-reports-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.75fr) minmax(280px, 1fr) minmax(280px, 1fr);
    gap: 0.85rem;
  }

  .featured-report {
    display: grid;
    min-height: 100%;
    text-decoration: none;
    color: inherit;
    border: 1px solid #8fb6dd;
    border-radius: 18px;
    overflow: hidden;
    background: linear-gradient(150deg, rgba(15, 58, 99, 0.98), rgba(20, 84, 140, 0.94) 56%, rgba(12, 80, 62, 0.92));
    box-shadow: 0 16px 30px rgba(15, 45, 74, 0.16);
    transition: transform 0.14s ease, box-shadow 0.14s ease, border-color 0.14s ease;
  }

  .featured-report:hover {
    transform: translateY(-2px);
    border-color: #7ca6d2;
    box-shadow: 0 20px 34px rgba(15, 45, 74, 0.2);
  }

  .featured-report--hero {
    grid-template-rows: 230px 1fr;
  }

  .featured-report__media {
    position: relative;
    overflow: hidden;
  }

  .featured-report__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(7, 21, 36, 0.08), rgba(7, 21, 36, 0.56));
  }

  .featured-report__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .featured-report__mark {
    position: absolute;
    right: 0.85rem;
    bottom: 0.85rem;
    z-index: 1;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(8, 22, 38, 0.76);
    border: 1px solid rgba(255, 255, 255, 0.18);
    display: grid;
    place-items: center;
    box-shadow: 0 10px 22px rgba(8, 22, 38, 0.22);
  }

  .featured-report__mark img {
    width: 30px;
    height: 30px;
    object-fit: contain;
  }

  .featured-report__badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    color: #eef7ff;
    background: rgba(8, 22, 38, 0.76);
    border: 1px solid rgba(255, 255, 255, 0.16);
  }

  .featured-report__badge--inline {
    position: static;
    justify-self: start;
    margin-bottom: 0.12rem;
    background: rgba(230, 242, 255, 0.16);
  }

  .featured-report__body {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.05rem 1.05rem;
    color: #eff6fb;
  }

  .featured-report__body strong {
    font-size: 1.35rem;
    line-height: 1.06;
    color: #fff;
  }

  .featured-report__meta {
    color: rgba(231, 241, 249, 0.9);
    font-weight: 600;
  }

  .featured-report__body .muted {
    color: rgba(227, 239, 248, 0.88);
    line-height: 1.5;
  }

  .featured-report__cta {
    margin-top: 0.3rem;
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    color: #eef7ff;
    font-weight: 800;
  }

  .featured-report__cta::after {
    content: "->";
    font-size: 0.92rem;
  }

  @media (max-width: 720px) {
    .home-shell {
      grid-template-columns: 1fr;
    }

    .home-rail {
      position: static;
    }

    .home-hero-brand {
      align-items: flex-start;
    }

    .home-hero-mark {
      width: 54px;
      height: 54px;
    }

    .featured-reports-grid {
      grid-template-columns: 1fr;
    }

    .featured-report--hero {
      grid-template-rows: 210px 1fr;
    }
  }
</style>
