---
import BaseLayout from "../layouts/BaseLayout.astro";
import teamNeeds from "../data/team_needs_2026.json";
import {
  TEAM_SEARCH_ALIASES,
  contractChipClass,
  contractChipLabel,
  normalizeSearch,
  designationClass,
  txClass,
  laneFor,
  lanePlayers,
  roleContractLine,
  metaLine,
  searchableText,
  teamDisplayName,
  teamPath,
} from "../lib/teamNeeds";

const pageDescription = "NFL Team Needs 2026 with team-by-team weakness tiers, contract pressure, free-agent exposure, and links to full team depth chart pages.";
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "NFL Team Needs 2026",
  url: "https://scoutinggrade.com/nfl-team-needs-2026",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com",
  },
};

const rows = (teamNeeds || []) as any[];
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "NFL Team Needs 2026 Rankings",
  itemListOrder: "https://schema.org/ItemListUnordered",
  numberOfItems: rows.length,
  itemListElement: rows.map((row: any, idx: number) => ({
    "@type": "ListItem",
    position: idx + 1,
    name: `${teamDisplayName(row.team)} top need: ${row?.top_needs?.[0]?.position || "N/A"}`,
    url: `https://scoutinggrade.com${teamPath(row.team)}`,
  })),
};

const sortedTeams = [...rows]
  .map((row) => String(row.team || "").trim())
  .filter(Boolean)
  .sort((a, b) => a.localeCompare(b));

const teamOptions = sortedTeams.map((team) => {
  const aliases = TEAM_SEARCH_ALIASES[team] || [team];
  const display = aliases.find((item) => {
    const upper = String(item || "").toUpperCase();
    return upper !== team.toUpperCase() && !upper.startsWith(team.toUpperCase());
  }) || team;
  return { team, display };
});

function snapshotLaneLabel(row: any, position: string) {
  const depthChart = (row.depth_chart || {}) as any;
  const offense = (depthChart.offense || []) as any[];
  const defense = (depthChart.defense || []) as any[];
  const lanes = ["QB", "RB", "WR", "TE", "OT", "IOL"].includes(position) ? offense : defense;
  const lane = laneFor(lanes, position);
  const players = lanePlayers(lane, 2);
  if (!players.length) return "No current lane data";
  return players.map((p: any) => `${p.player_name} (${p.role_label || p.position})`).join(" • ");
}
---
<BaseLayout
  title="NFL Team Needs 2026 by Team | Scouting Grade"
  description={pageDescription}
  keywords={["nfl team needs 2026", "team needs nfl draft", "nfl free agency team needs", "scouting grade"]}
  collectionSchema={collectionSchema}
  extraSchemas={[itemListSchema]}
>
  <section class="hero hero--data">
    <h1>NFL Team Needs 2026</h1>
    <p>Overview page for every roster’s top need stack, contract pressure, and trajectory. Open each team page for the full depth chart, contract detail, and transaction context.</p>
  </section>

  <section class="card page-intro">
    <h2 class="section-title">League-Wide Need Stack</h2>
    <p class="muted">
      This page is the fastest way to scan every roster’s top needs, free-agent pressure, and current direction heading into the 2026 draft.
      Open the full team page for deeper room detail, contract watch, and the full field-view depth chart.
    </p>
  </section>

  <section class="card">
    <div class="result-bar">
      <div class="muted">Showing {rows.length} teams.</div>
      <button type="button" class="reset-btn" id="reset-team-needs-filters">Reset Filters</button>
    </div>

    <div class="filters-grid team-needs-filters">
      <input
        class="control search-control"
        id="team-needs-search"
        type="search"
        placeholder="Search team, position need, or player..."
        autocomplete="off"
      />
      <select class="control" id="team-needs-team">
        <option value="">All Teams</option>
        {teamOptions.map((entry) => (
          <option value={entry.team}>{entry.team} — {entry.display}</option>
        ))}
      </select>
    </div>
  </section>

  <section class="card related-links">
    <h2 class="section-title">Related Draft Tools</h2>
    <div class="related-links-grid">
      <a class="related-link" href="/2026-nfl-mock-draft">
        <strong>Mock Draft Hub</strong>
        <span class="muted">See how roster pressure and team need are shaping the current projection.</span>
      </a>
      <a class="related-link" href="/2026-nfl-draft-big-board">
        <strong>Big Board</strong>
        <span class="muted">Cross-check team need against the best available talent on the full board.</span>
      </a>
      <a class="related-link" href="/nfl-transactions-feed-2026">
        <strong>Transactions Feed</strong>
        <span class="muted">Track confirmed moves and rumor monitoring behind the team-needs updates.</span>
      </a>
    </div>
  </section>

  <section class="team-needs-grid" id="team-needs-grid">
    {rows.map((row) => {
      const team = String(row.team || "").trim();
      const topNeeds = (row.top_needs || []) as any[];
      const weakness = (row.weakness_positions || []) as string[];
      const freeAgents = (row.free_agents || []) as any[];
      const youngPlayers = (row.young_players_on_rise || []) as any[];
      const tx = (row.recent_transactions || []) as any[];
      const needPositions = topNeeds.slice(0, 3).map((need: any) => String(need.position || "").trim()).filter(Boolean);
      return (
        <article class="card team-card team-card--overview" data-team={team} data-search={searchableText(row)}>
          <header class="team-card__head">
            <div class="team-card__title-row">
              <div>
                <h2><a class="player-link" href={teamPath(team)}>{teamDisplayName(team)}</a></h2>
                <div class="muted team-card__abbr">{team}</div>
              </div>
              <a class="overview-cta" href={teamPath(team)}>Full Team Page</a>
            </div>
            <div class="team-card__need-pills">
              {topNeeds.map((need: any, idx: number) => (
                <span class="chip info">{`Need ${idx + 1}: ${need.position} (${Number(need.need_score || 0).toFixed(2)})`}</span>
              ))}
            </div>
            <div class="muted team-card__weakness">Weakness focus: {weakness.length ? weakness.join(" • ") : "n/a"}</div>
          </header>

          <div class="team-card__columns">
            <section class="team-card__block">
              <h3>Key Free Agents</h3>
              {freeAgents.length > 0 ? (
                <div class="team-pill-list">
                  {freeAgents.slice(0, 2).map((p: any) => (
                    <div class="team-pill">
                      <div class="depth-player__top">
                        <strong>{p.player_name}</strong>
                        <div class="depth-player__chips">
                          <span class={designationClass(p.designation)}>{p.designation}</span>
                          <span class={contractChipClass(p)}>{contractChipLabel(p)}</span>
                        </div>
                      </div>
                      <div class="muted">{roleContractLine(p)}</div>
                      {metaLine(p) ? <div class="muted">{metaLine(p)}</div> : null}
                    </div>
                  ))}
                  {freeAgents.length > 2 ? <div class="muted">+{freeAgents.length - 2} more on full team page</div> : null}
                </div>
              ) : (
                <p class="muted">No high-value unsigned or contract-watch players flagged this refresh.</p>
              )}
            </section>

            <section class="team-card__block">
              <h3>Young Players On The Rise</h3>
              {youngPlayers.length > 0 ? (
                <div class="team-pill-list">
                  {youngPlayers.slice(0, 2).map((p: any) => (
                    <div class="team-pill">
                      <strong>{p.player_name}</strong>
                      <span class={designationClass(p.designation)}>{p.designation}</span>
                      <div class="muted">{roleContractLine(p)}</div>
                      {metaLine(p) ? <div class="muted">{metaLine(p)}</div> : null}
                    </div>
                  ))}
                  {youngPlayers.length > 2 ? <div class="muted">+{youngPlayers.length - 2} more on full team page</div> : null}
                </div>
              ) : (
                <p class="muted">No rising-player signal flagged this refresh.</p>
              )}
            </section>
          </div>

          <section class="team-card__block">
            <h3>Depth Snapshot</h3>
            <div class="overview-snapshot-grid">
              {needPositions.map((position) => (
                <div class="overview-snapshot-card">
                  <div class="overview-snapshot-card__head">
                    <span class="badge">{position}</span>
                  </div>
                  <div class="muted">{snapshotLaneLabel(row, position)}</div>
                </div>
              ))}
            </div>
          </section>

          <section class="team-card__block">
            <div class="team-card__subhead">
              <h3>Recent Transactions</h3>
              <a class="team-card__subhead-link" href={teamPath(team)}>Open full team page</a>
            </div>
            {tx.length > 0 ? (
              <div class="tx-list">
                {tx.slice(0, 2).map((item: any) => (
                  <div class="tx-row">
                    <span class={txClass(item.status_kind)}>{item.status}</span>
                    <strong>{item.label}</strong>
                    <span class="muted">{item.event_date}</span>
                  </div>
                ))}
              </div>
            ) : (
              <p class="muted">No recent transactions in this window.</p>
            )}
          </section>
        </article>
      );
    })}
  </section>

  <script>
    (() => {
      const searchEl = document.getElementById("team-needs-search");
      const teamEl = document.getElementById("team-needs-team");
      const resetEl = document.getElementById("reset-team-needs-filters");
      const cards = Array.from(document.querySelectorAll(".team-card"));

      if (!searchEl || !teamEl || cards.length === 0) return;

      const normalizeSearch = (value) => {
        return String(value || "")
          .toLowerCase()
          .normalize("NFKD")
          .replace(/[^a-z0-9]+/g, " ")
          .replace(/\s+/g, " ")
          .trim();
      };

      const applyFilters = () => {
        const search = normalizeSearch(searchEl.value || "");
        const team = String(teamEl.value || "").trim().toLowerCase();

        for (const card of cards) {
          const cardTeam = String(card.getAttribute("data-team") || "").toLowerCase();
          const hay = normalizeSearch(card.getAttribute("data-search"));
          const teamOk = !team || cardTeam === team;
          const searchOk = !search || hay.includes(search);
          card.style.display = teamOk && searchOk ? "" : "none";
        }
      };

      const resetFilters = () => {
        searchEl.value = "";
        teamEl.value = "";
        applyFilters();
      };

      searchEl.addEventListener("input", applyFilters);
      teamEl.addEventListener("change", applyFilters);
      resetEl?.addEventListener("click", resetFilters);
    })();
  </script>
</BaseLayout>
