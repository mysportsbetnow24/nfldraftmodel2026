---
import BaseLayout from "../layouts/BaseLayout.astro";
import board from "../data/big_board_2026.json";

const pool = (board || []).slice(0, 180);
const pageDescription = "Compare 2026 NFL Draft prospects side-by-side by model rank, grade, PFF, trait score, and RAS.";
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "2026 NFL Player Comparison",
  url: "https://scoutinggrade.com/2026-nfl-player-comparison",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
---
<BaseLayout title="2026 NFL Player Comparison | Scouting Grade" description={pageDescription} collectionSchema={collectionSchema}>
  <section class="hero">
    <h1>2026 NFL Player Comparison</h1>
    <p>Brief side-by-side snapshot: model rank/grade, PFF, traits, and RAS.</p>
  </section>

  <section class="card" style="margin-bottom:1rem;">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.65rem;">
      <select id="p1"><option value="">Select Player 1</option>{pool.map((p:any)=><option value={p.player_uid}>{p.player_name} ({p.position})</option>)}</select>
      <select id="p2"><option value="">Select Player 2</option>{pool.map((p:any)=><option value={p.player_uid}>{p.player_name} ({p.position})</option>)}</select>
      <select id="p3"><option value="">Select Player 3</option>{pool.map((p:any)=><option value={p.player_uid}>{p.player_name} ({p.position})</option>)}</select>
      <select id="p4"><option value="">Select Player 4</option>{pool.map((p:any)=><option value={p.player_uid}>{p.player_name} ({p.position})</option>)}</select>
    </div>
  </section>

  <section id="cards" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:.8rem;"></section>

  <script define:vars={{ pool }}>
    const idx = {};
    pool.forEach((p) => { idx[p.player_uid] = p; });
    const slots = ["p1", "p2", "p3", "p4"].map((id) => document.getElementById(id));
    const cards = document.getElementById("cards");
    const fmt = (v) => (v === null || v === undefined || v === "" ? "-" : String(v));
    const pff = (p) => {
      const n = Number(p.pff_grade || 0);
      return n > 0 ? n.toFixed(1) : "-";
    };
    const trait = (p) => {
      const n = Number(p.trait_score || 0);
      return n > 0 ? n.toFixed(2) : "-";
    };
    const ras = (p) => {
      const off = Number(p.combine_ras_official || 0);
      if (off > 0) return off.toFixed(2);
      const est = Number(p.ras_estimate || 0);
      if (est > 0) return `${est.toFixed(2)} (est.)`;
      return "-";
    };
    const rasRaw = (p) => {
      const off = Number(p.combine_ras_official || 0);
      if (off > 0) return off;
      const est = Number(p.ras_estimate || 0);
      return est > 0 ? est : 0;
    };
    const pct = (value, min, max) => {
      const n = Number(value);
      if (!Number.isFinite(n) || n <= 0) return 0;
      const p = ((n - min) / (max - min)) * 100;
      return Math.max(0, Math.min(100, p));
    };
    const metricRow = (label, displayValue, widthPct, tone = "var(--brand)") => `
      <div class="metric-row">
        <div class="metric-top">
          <span>${label}</span>
          <strong>${displayValue}</strong>
        </div>
        <div class="meter">
          <div class="meter-fill" style="width:${widthPct.toFixed(1)}%;background:${tone};"></div>
        </div>
      </div>
    `;
    const radarSvg = (vals) => {
      const angles = [-90, 0, 90, 180];
      const cx = 62;
      const cy = 62;
      const radius = 46;
      const point = (pct, angle) => {
        const r = radius * (Math.max(0, Math.min(100, pct)) / 100);
        const rad = (angle * Math.PI) / 180;
        return `${(cx + Math.cos(rad) * r).toFixed(1)},${(cy + Math.sin(rad) * r).toFixed(1)}`;
      };
      const poly = vals.map((v, i) => point(v, angles[i])).join(" ");
      const rings = [20, 40, 60, 80, 100].map((ring) => {
        const rr = radius * (ring / 100);
        const p = angles.map((a) => {
          const rad = (a * Math.PI) / 180;
          return `${(cx + Math.cos(rad) * rr).toFixed(1)},${(cy + Math.sin(rad) * rr).toFixed(1)}`;
        }).join(" ");
        return `<polygon points="${p}" fill="none" stroke="#d9e1ea" stroke-width="1"/>`;
      }).join("");
      const axes = angles.map((a) => {
        const rad = (a * Math.PI) / 180;
        const x = (cx + Math.cos(rad) * radius).toFixed(1);
        const y = (cy + Math.sin(rad) * radius).toFixed(1);
        return `<line x1="${cx}" y1="${cy}" x2="${x}" y2="${y}" stroke="#d9e1ea" stroke-width="1"/>`;
      }).join("");
      return `
        <svg viewBox="0 0 124 124" width="124" height="124" aria-label="player radar">
          ${rings}
          ${axes}
          <polygon points="${poly}" fill="rgba(13,47,79,0.20)" stroke="var(--brand)" stroke-width="2"/>
        </svg>
      `;
    };

    const render = () => {
      const chosen = slots.map((el) => idx[el?.value]).filter(Boolean);
      cards.innerHTML = "";
      chosen.forEach((p) => {
        const modelGrade = Number(p.final_grade || 0);
        const pffGrade = Number(p.pff_grade || 0);
        const traitScore = Number(p.trait_score || 0);
        const rasScore = rasRaw(p);
        const rankScore = Number.isFinite(Number(p.consensus_rank)) && Number(p.consensus_rank) > 0
          ? Math.max(0, Math.min(100, ((300 - Number(p.consensus_rank)) / 300) * 100))
          : 0;
        const radar = radarSvg([
          pct(modelGrade, 65, 95),
          pct(pffGrade, 55, 95),
          pct(traitScore, 70, 97),
          pct(rasScore, 4, 10)
        ]);
        const div = document.createElement("article");
        div.className = "card compare-card";
        div.innerHTML = `
          <h3 style="margin:0 0 .2rem;font-size:1.45rem;">${p.player_name}</h3>
          <div class="muted">${p.school}</div>
          <div style="margin:.6rem 0 .5rem;">
            <span class="badge">${p.position}</span>
            <span class="badge">Model Rank ${fmt(p.consensus_rank)}</span>
            <span class="badge">${p.low_evidence_flag ? "QA Watch" : "QA Clear"}</span>
          </div>
          <div class="muted" style="margin:0 0 .55rem;"><strong>Projected Range:</strong> ${fmt(p.round_value)}</div>
          <div class="compare-viz-row">
            <div class="radar-wrap">
              ${radar}
              <div class="radar-legend muted">G/P/T/R</div>
            </div>
            <div class="rank-snapshot">
              <div class="muted">Board Strength</div>
              <strong>${rankScore.toFixed(0)}</strong>
            </div>
          </div>
          <div class="metrics-wrap">
            ${metricRow("Model Grade", fmt(p.final_grade), pct(modelGrade, 65, 95), "var(--brand)")}
            ${metricRow("PFF Grade", pff(p), pct(pffGrade, 55, 95), "var(--accent)")}
            ${metricRow("Trait Score", trait(p), pct(traitScore, 70, 97), "#0f7b6a")}
            ${metricRow("RAS Score", ras(p), pct(rasScore, 4, 10), "#6b7280")}
          </div>
        `;
        cards.appendChild(div);
      });
    };

    // Preload top prospects so page has immediate comparisons.
    if (pool[0] && slots[0] && !slots[0].value) slots[0].value = pool[0].player_uid;
    if (pool[1] && slots[1] && !slots[1].value) slots[1].value = pool[1].player_uid;
    if (pool[2] && slots[2] && !slots[2].value) slots[2].value = pool[2].player_uid;
    if (pool[3] && slots[3] && !slots[3].value) slots[3].value = pool[3].player_uid;

    slots.forEach((el) => el?.addEventListener("change", render));
    render();
  </script>

  <style>
    .compare-card {
      padding: 1rem;
    }
    .compare-viz-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .7rem;
      margin: .35rem 0 .55rem;
    }
    .radar-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .2rem;
      min-width: 130px;
    }
    .radar-legend {
      font-size: .72rem;
      letter-spacing: .06em;
      text-transform: uppercase;
    }
    .rank-snapshot {
      border: 1px solid #e6ebf1;
      border-radius: 10px;
      padding: .45rem .55rem;
      min-width: 96px;
      text-align: center;
      background: #fbfdff;
    }
    .rank-snapshot strong {
      display: block;
      font-size: 1.25rem;
      margin-top: .18rem;
      color: var(--brand);
    }
    .metrics-wrap {
      display: grid;
      gap: .5rem;
      margin-top: .4rem;
    }
    .metric-row {
      border: 1px solid #e6ebf1;
      border-radius: 10px;
      padding: .45rem .5rem;
      background: #fbfdff;
    }
    .metric-top {
      display: flex;
      justify-content: space-between;
      gap: .45rem;
      font-size: .86rem;
      margin-bottom: .28rem;
    }
    .meter {
      width: 100%;
      background: #ebeff4;
      border-radius: 999px;
      height: 8px;
      overflow: hidden;
    }
    .meter-fill {
      height: 100%;
      border-radius: 999px;
      transition: width .2s ease;
    }
    @media (max-width: 760px) {
      .compare-card {
        padding: .85rem;
      }
      .compare-viz-row {
        flex-direction: column;
        align-items: flex-start;
      }
      .rank-snapshot {
        width: 100%;
      }
    }
  </style>
</BaseLayout>
