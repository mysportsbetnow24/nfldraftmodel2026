---
import BaseLayout from "../layouts/BaseLayout.astro";
import board from "../data/big_board_2026.json";

const pool = (board || []).slice(0, 220);
const pageDescription = "Position-aware 2026 NFL Draft player comparison with production percentiles, traits, athletic profile, market context, role fit, and historical comps.";
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "2026 NFL Player Comparison",
  url: "https://scoutinggrade.com/2026-nfl-player-comparison",
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    name: "Scouting Grade",
    url: "https://scoutinggrade.com"
  }
};
---
<BaseLayout title="2026 NFL Player Comparison | Scouting Grade" description={pageDescription} collectionSchema={collectionSchema} shellClass="compare-shell">
  <section class="hero hero--data compare-hero">
    <h1>2026 NFL Player Comparison</h1>
    <p>Side-by-side view of rank, grade, key signals, translation profile, and historical comp context.</p>
  </section>

  <section class="card page-intro">
    <h2 class="section-title">Compare Prospects Side by Side</h2>
    <p class="muted">
      Use the comparison tool to stack prospects by grade, production profile, athletic profile, role fit, and historical comps. It is built
      to show where players separate inside the same class and how their NFL translation profile differs at a glance.
    </p>
  </section>

  <section class="card compare-controls">
    <h2 class="section-title">Select Prospects</h2>
    <div class="compare-grid">
      <select id="compare-position" class="control">
        <option value="">All Positions</option>
        {[...new Set(pool.map((p:any) => String(p.position || "").toUpperCase()).filter(Boolean))].sort().map((pos) => (
          <option value={pos}>{pos}</option>
        ))}
      </select>
      {[1,2,3,4].map((slotNum) => (
        <div class="compare-slot-control">
          <input
            id={`p${slotNum}-search`}
            class="control search-control"
            type="search"
            placeholder={`Search Player ${slotNum}`}
            autocomplete="off"
          />
          <select id={`p${slotNum}`} class="control">
            <option value="">Select Player {slotNum}</option>
            {pool.map((p:any)=><option value={p.player_uid}>{p.player_name} ({p.position})</option>)}
          </select>
        </div>
      ))}
    </div>
  </section>

  <section class="card related-links">
    <h2 class="section-title">Related Draft Tools</h2>
    <div class="related-links-grid">
      <a class="related-link" href="/2026-nfl-draft-big-board">
        <strong>Big Board</strong>
        <span class="muted">Move from side-by-side comparison to the full class ranking stack.</span>
      </a>
      <a class="related-link" href="/2026-nfl-mock-draft">
        <strong>Mock Draft Hub</strong>
        <span class="muted">See how those player differences translate into projected NFL landing spots.</span>
      </a>
      <a class="related-link" href="/scouting-cards">
        <strong>Scouting Cards</strong>
        <span class="muted">Open the full written scouting reports and film-driven notes for top prospects.</span>
      </a>
    </div>
  </section>

  <section id="cards" class="cards-grid compare-cards"></section>

  <script define:vars={{ pool }}>
    const idx = {};
    pool.forEach((p) => { idx[p.player_uid] = p; });
    const positionFilter = document.getElementById("compare-position");
    const slots = ["p1", "p2", "p3", "p4"].map((id) => document.getElementById(id));
    const slotSearches = ["p1-search", "p2-search", "p3-search", "p4-search"].map((id) => document.getElementById(id));
    const cards = document.getElementById("cards");
    const normalizeSearch = (value) => String(value || "").toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();

    const filteredPool = (slotIdx) => {
      const query = normalizeSearch(slotSearches[slotIdx]?.value || "");
      const position = String(positionFilter?.value || "").toUpperCase();
      return pool.filter((p) => {
        const pos = String(p.position || "").toUpperCase();
        if (position && pos !== position) return false;
        if (!query) return true;
        const haystack = normalizeSearch([p.player_name, p.position, p.school].join(" "));
        return haystack.includes(query);
      });
    };

    const repopulateSlotOptions = () => {
      const selectedValues = slots.map((el) => el?.value).filter(Boolean);
      slots.forEach((el, idxNum) => {
        if (!el) return;
        const available = filteredPool(idxNum);
        const currentValue = el.value;
        const placeholder = `Select Player ${idxNum + 1}`;
        const currentPlayer = currentValue ? idx[currentValue] : null;
        const optionPlayers = [];
        const seen = new Set();
        if (currentPlayer) {
          optionPlayers.push(currentPlayer);
          seen.add(currentPlayer.player_uid);
        }
        available.forEach((player) => {
          if (seen.has(player.player_uid)) return;
          optionPlayers.push(player);
          seen.add(player.player_uid);
        });

        el.innerHTML = "";
        const first = document.createElement("option");
        first.value = "";
        first.textContent = placeholder;
        el.appendChild(first);

        optionPlayers.forEach((player) => {
          const option = document.createElement("option");
          option.value = player.player_uid;
          option.textContent = `${player.player_name} (${player.position})`;
          if (currentValue === player.player_uid) {
            option.selected = true;
          } else if (selectedValues.includes(player.player_uid)) {
            option.disabled = true;
          }
          el.appendChild(option);
        });
      });
    };

    const fmtValue = (n, mode) => {
      if (!Number.isFinite(n)) return "-";
      if (mode === "int") return Math.round(n).toString();
      if (mode === "pct") return `${(n * 100).toFixed(1)}%`;
      if (mode === "pct100") return `${n.toFixed(1)}%`;
      if (mode === "dec1") return n.toFixed(1);
      if (mode === "dec3") return n.toFixed(3);
      return n.toFixed(2);
    };

    const num = (v) => {
      const n = Number(v);
      return Number.isFinite(n) ? n : null;
    };

    const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));
    const toPct = (value, min, max) => {
      const n = Number(value);
      if (!Number.isFinite(n)) return 0;
      return clamp(((n - min) / (max - min)) * 100, 0, 100);
    };

    const marketSignalState = (p) => {
      const raw = Number(p.market_signal_pct);
      const pct = Number.isFinite(raw) ? clamp(raw, 0, 100) : 50;
      if (pct >= 80) return { label: "Strong", pct, tone: "good" };
      if (pct >= 55) return { label: "Balanced", pct, tone: "info" };
      return { label: "Contrarian", pct, tone: "warn" };
    };

    const parseTopDrivers = (summary) => {
      const out = [];
      String(summary || "").split("|").forEach((chunk) => {
        const [k, v] = chunk.split(":");
        const key = String(k || "").trim();
        const val = Number((v || "").trim());
        if (!key || !Number.isFinite(val)) return;
        out.push({ key, val });
      });
      out.sort((a, b) => Math.abs(b.val) - Math.abs(a.val));
      return out.slice(0, 3);
    };

    const metricCardMap = (p) => {
      const out = {};
      (p.advanced_metric_cards || []).forEach((m) => {
        out[m.key] = m;
      });
      return out;
    };

    const avgPct = (cards, keys, fallback = 50) => {
      const vals = keys
        .map((k) => Number(cards[k]?.pct))
        .filter((n) => Number.isFinite(n));
      if (!vals.length) return fallback;
      return vals.reduce((a, b) => a + b, 0) / vals.length;
    };

    const positionLens = (p, productionPct) => {
      const cards = metricCardMap(p);
      const pos = String(p.position || "").toUpperCase();
      if (pos === "QB") {
        return {
          title: "QB Stress / Process",
          tags: [],
          rows: [
            { label: "Stress Response", pct: avgPct(cards, ["sg_qb_pressure_grade", "sg_qb_pressure_to_sack_rate", "sg_qb_blitz_grade"]), detail: "pressure, sack avoidance, blitz answers" },
            { label: "Decision Quality", pct: avgPct(cards, ["sg_qb_btt_rate", "sg_qb_twp_rate", "sg_qb_pass_grade"]), detail: "aggression balanced with turnover control" },
            { label: "Starter Translation", pct: avgPct(cards, ["sg_qb_pass_grade", "sg_qb_blitz_grade"]), detail: "pass grade and pro-style stress handling" },
          ],
        };
      }
      if (pos === "RB") {
        return {
          title: "RB Three-Down Creator",
          tags: [],
          rows: [
            { label: "Creation After Contact", pct: avgPct(cards, ["sg_rb_run_grade", "sg_rb_elusive_rating", "sg_rb_yco_attempt"]), detail: "run grade, elusive value, yards after contact" },
            { label: "Explosive Threat", pct: avgPct(cards, ["sg_rb_explosive_rate", "sg_rb_breakaway_percent"]), detail: "chunk gains and home-run carry profile" },
            { label: "Passing-Down Value", pct: avgPct(cards, ["sg_rb_targets_per_route", "sg_rb_run_grade"], productionPct), detail: "receiving involvement and snap-stay utility" },
          ],
        };
      }
      if (pos === "WR" || pos === "TE") {
        return {
          title: `${pos === "TE" ? "TE" : "WR"} Route Earner`,
          tags: [],
          rows: [
            { label: "Route Earning", pct: avgPct(cards, ["sg_wrte_route_grade", "sg_wrte_yprr", "sg_wrte_targets_per_route"]), detail: "route quality plus target-earning efficiency" },
            { label: "Coverage Translation", pct: avgPct(cards, ["sg_wrte_man_yprr", "sg_wrte_zone_yprr", "sg_wrte_route_grade"]), detail: "production across coverage families" },
            { label: "Ball Reliability", pct: avgPct(cards, ["sg_wrte_drop_rate", "sg_wrte_targets_per_route"], productionPct), detail: "hands and stable passing-game utility" },
          ],
        };
      }
      if (pos === "EDGE" || pos === "DT") {
        return {
          title: "True-Pass-Set Disruption",
          tags: [],
          rows: [
            { label: "Rush Translation", pct: avgPct(cards, ["sg_dl_pass_rush_grade", "sg_dl_true_pass_set_win_rate", "sg_dl_true_pass_set_prp"]), detail: "clean pass-rush quality when protections are honest" },
            { label: "Pressure Load", pct: avgPct(cards, ["sg_dl_total_pressures", "sg_dl_pass_rush_grade"]), detail: "how often disruption actually shows up" },
            { label: "Run-Down Utility", pct: avgPct(cards, ["sg_front_run_def_grade", "sg_front_stop_percent"]), detail: "base-down viability alongside rush value" },
          ],
        };
      }
      if (pos === "CB" || pos === "S") {
        return {
          title: "DB Coverage Tax",
          tags: [],
          rows: [
            { label: "Target Deterrence", pct: avgPct(cards, ["sg_cov_snaps_per_target", "sg_cov_yards_per_snap"]), detail: "how expensive it is to attack this defender" },
            { label: "Ball Disruption", pct: avgPct(cards, ["sg_cov_forced_incompletion_rate", "sg_cov_qb_rating_against"]), detail: "forced misses and passer suppression" },
            { label: "Scheme Translation", pct: avgPct(cards, pos === "CB" ? ["sg_cov_grade", "sg_cov_man_grade"] : ["sg_cov_grade", "sg_cov_zone_grade"]), detail: "coverage quality in likely NFL usage" },
          ],
        };
      }
      if (pos === "OT" || pos === "IOL") {
        return {
          title: "OL Pass-Pro Translation",
          tags: [],
          rows: [
            { label: "Pass-Pro Core", pct: avgPct(cards, ["sg_ol_pass_block_grade", "sg_ol_pbe", "sg_ol_pressure_allowed_rate"]), detail: "block quality plus pressure suppression" },
            { label: "Run-Game Lift", pct: avgPct(cards, ["sg_ol_run_block_grade"], productionPct), detail: "movement and run-game support" },
            { label: "Alignment Flex", pct: avgPct(cards, ["sg_ol_versatility_count"], productionPct), detail: "multi-spot utility and lineup resilience" },
          ],
        };
      }
      if (pos === "LB") {
        return {
          title: "LB Dual-Threat Defender",
          tags: [],
          rows: [
            { label: "Run-Game Control", pct: avgPct(cards, ["sg_def_run_grade", "sg_front_stop_percent"]), detail: "run fits and stop creation" },
            { label: "Coverage Range", pct: avgPct(cards, ["sg_def_coverage_grade", "sg_cov_yards_per_snap"]), detail: "how playable he is in space" },
            { label: "Tackle Finish", pct: avgPct(cards, ["sg_def_tackle_grade", "sg_def_missed_tackle_rate"]), detail: "clean finish and down-to-down reliability" },
          ],
        };
      }
      return {
        title: "ScoutingGrade Lens",
        tags: [],
        rows: [
          { label: "Translation Profile", pct: productionPct, detail: "position-specific production composite" },
        ],
      };
    };

    const sparkline = (ranks = []) => {
      const points = ranks.map((r) => Number(r)).filter((n) => Number.isFinite(n) && n > 0);
      if (points.length < 2) return `<div class="muted">Trend: limited history</div>`;
      const w = 180;
      const h = 42;
      const min = Math.min(...points);
      const max = Math.max(...points);
      const span = Math.max(1, max - min);
      const coords = points.map((r, i) => {
        const x = (i / (points.length - 1)) * (w - 8) + 4;
        const y = ((r - min) / span) * (h - 8) + 4;
        return `${x.toFixed(1)},${y.toFixed(1)}`;
      }).join(" ");
      return `
        <svg viewBox="0 0 ${w} ${h}" width="100%" height="42" aria-label="rank trend">
          <polyline points="${coords}" fill="none" stroke="#245ea8" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></polyline>
        </svg>
      `;
    };

    const radarSvg = (values) => {
      const labels = ["Production", "Athletic", "Traits", "Market"];
      const w = 280;
      const h = 280;
      const cx = 140;
      const cy = 140;
      const maxR = 92;
      const rings = [20, 40, 60, 80, 100];

      const pointAt = (pct, i) => {
        const angle = (-90 + i * 90) * (Math.PI / 180);
        const radius = (clamp(pct, 0, 100) / 100) * maxR;
        const x = cx + Math.cos(angle) * radius;
        const y = cy + Math.sin(angle) * radius;
        return [x, y];
      };

      const poly = values.map((v, i) => pointAt(v, i).map((n) => n.toFixed(1)).join(",")).join(" ");

      const ringPolys = rings.map((pct) => {
        const pts = [0, 1, 2, 3]
          .map((i) => pointAt(pct, i).map((n) => n.toFixed(1)).join(","))
          .join(" ");
        return `<polygon points="${pts}" fill="none" stroke="#d4deea" stroke-width="1"/>`;
      }).join("");

      const axes = [0, 1, 2, 3].map((i) => {
        const [x, y] = pointAt(100, i);
        return `<line x1="${cx}" y1="${cy}" x2="${x.toFixed(1)}" y2="${y.toFixed(1)}" stroke="#d4deea" stroke-width="1"/>`;
      }).join("");

      const labelNodes = [
        [cx, cy - maxR - 14],
        [cx + maxR + 18, cy + 4],
        [cx, cy + maxR + 18],
        [cx - maxR - 18, cy + 4]
      ].map((pos, i) => {
        const anchor = i === 0 || i === 2 ? "middle" : (i === 1 ? "start" : "end");
        return `<text x="${pos[0]}" y="${pos[1]}" fill="#4b5563" font-size="11" text-anchor="${anchor}">${labels[i]}</text>`;
      }).join("");

      return `
        <svg viewBox="0 0 ${w} ${h}" role="img" aria-label="Translation profile radar">
          ${ringPolys}
          ${axes}
          <polygon points="${poly}" fill="rgba(31, 94, 168, 0.22)" stroke="#1f5ea8" stroke-width="2"/>
          ${labelNodes}
        </svg>
      `;
    };

    const meterRow = (label, pct, valueText, tone = "var(--brand)") => `
      <div class="metric-row">
        <div class="metric-top">
          <span>${label}</span>
          <strong>${valueText}</strong>
        </div>
        <div class="meter"><div class="meter-fill" style="width:${clamp(pct, 0, 100).toFixed(1)}%;background:${tone};"></div></div>
      </div>
    `;

    const productionRows = (p) => {
      const rows = (p.advanced_metric_cards || []).map((m) => {
        const pp = clamp(Number(m.pct || 50), 0, 100);
        return meterRow(`${m.label} (${p.position})`, pp, `${m.display || fmtValue(Number(m.raw), m.fmt)} · ${pp.toFixed(0)}th pct`, "#0f7b6a");
      }).filter(Boolean);
      if (!rows.length) return `<div class="muted">ScoutingGrade advanced context will appear after next refresh.</div>`;
      return rows.join("");
    };

    const compLine = (title, comp, fallback) => {
      if (!comp || !comp.name) return `<div class="muted">${title}: ${fallback || "-"}</div>`;
      const simRaw = Number(comp.similarity);
      const sim = Number.isFinite(simRaw) ? (simRaw <= 1 ? simRaw * 100 : simRaw) : null;
      const simText = sim !== null ? `${sim.toFixed(1)}%` : "-";
      const yearText = comp.year ? ` (${comp.year})` : "";
      return `<div class="comp-row"><span>${title}:</span> <strong>${comp.name}${yearText}</strong> <span class="muted">· ${simText} profile similarity</span></div>`;
    };

    const roleTags = (p) => {
      const role = String(p.best_role || "Role projection");
      const scheme = String(p.best_scheme_fit || "Scheme projection");
      const tags = [];
      const s = scheme.toLowerCase();
      if (s.includes("zone")) tags.push("Zone");
      if (s.includes("man")) tags.push("Man");
      if (s.includes("gap")) tags.push("Gap");
      if (s.includes("blitz")) tags.push("Pressure");
      if (s.includes("run")) tags.push("Run-first");
      return { role, scheme, tags };
    };

    const render = () => {
      const chosen = slots.map((el) => idx[el?.value]).filter(Boolean);
      cards.innerHTML = "";
      chosen.forEach((p) => {
        const grade = Number(p.final_grade || 0);
        const pff = Number(p.pff_grade || 0);
        const trait = Number(p.trait_score || 0);
        const rasRaw = Number(p.combine_ras_official || 0) > 0 ? Number(p.combine_ras_official || 0) : Number(p.ras_estimate || 0);
        const ras = rasRaw > 0 ? rasRaw.toFixed(2) : "-";
        const market = marketSignalState(p);
        const topDrivers = parseTopDrivers(p.rank_driver_summary || "");
        const move = Number(p.rank_move_window || 0);
        const moveText = move > 0 ? `Up ${move}` : (move < 0 ? `Down ${Math.abs(move)}` : "Flat");
        const role = roleTags(p);

        const productionPctRaw = Number(p.production_composite_pct);
        const productionPct = Number.isFinite(productionPctRaw) ? clamp(productionPctRaw, 0, 100) : 50;
        const athleticPctRaw = num(p.athletic_percentile);
        const athleticPct = athleticPctRaw === null ? (rasRaw > 0 ? toPct(rasRaw, 4, 10) : 50) : clamp(athleticPctRaw, 0, 100);
        const athleticTesting = clamp(Number(p.athletic_testing_score || 50), 0, 100);
        const athleticFrame = clamp(Number(p.athletic_frame_score || 50), 0, 100);
        const athleticConfidence = clamp(Number(p.athletic_source_confidence || 50), 0, 100);
        const traitPctRaw = Number(p.trait_percentile);
        const traitPct = Number.isFinite(traitPctRaw) ? clamp(traitPctRaw, 0, 100) : toPct(trait, 70, 97);
        const marketPct = clamp(Number(market.pct || 50), 0, 100);
        const lens = (p.position_lens && Array.isArray(p.position_lens.rows) && p.position_lens.rows.length)
          ? p.position_lens
          : positionLens(p, productionPct);

        const div = document.createElement("article");
        div.className = "card compare-card";
        div.innerHTML = `
          <div class="profile-strip">
            <div class="card-head">
              <h3>${p.player_name}</h3>
              <span class="badge">${p.position}</span>
            </div>
            <div class="muted">${p.school}</div>
            <div class="muted keyline">Model Rank ${p.consensus_rank} · Grade ${grade.toFixed(2)} · ${p.round_value || "-"}</div>
            <div class="kpi-row">
              <span class="chip info">Rank ${p.consensus_rank}</span>
              <span class="chip info">PFF ${pff > 0 ? pff.toFixed(1) : "-"}</span>
              <span class="chip info">RAS ${ras}</span>
              <span class="chip ${market.tone === "good" ? "good" : (market.tone === "warn" ? "warn" : "info")}">Market ${market.label}</span>
            </div>
            ${p.player_report_url ? `<div class="compare-cta-row"><a class="compare-cta" href="${p.player_report_url}">Full Scouting Card</a></div>` : ``}
          </div>

          <div class="translation-block">
            <div class="radar-wrap">
              ${radarSvg([productionPct, athleticPct, traitPct, marketPct])}
            </div>
            <div class="bar-metrics">
              ${meterRow("Production Percentile", productionPct, `${productionPct.toFixed(0)}th pct`, "#0f7b6a")}
              ${meterRow("Athletic Profile Percentile", athleticPct, `${athleticPct.toFixed(0)}th pct`, "#425466")}
              <div class="chip-row">
                <span class="chip info">Testing ${athleticTesting.toFixed(0)}/100</span>
                <span class="chip info">Frame ${athleticFrame.toFixed(0)}/100</span>
                <span class="chip info">Confidence ${athleticConfidence.toFixed(0)}%</span>
              </div>
              ${meterRow("Trait Percentile", traitPct, `${traitPct.toFixed(0)}th pct`, "#245ea8")}
              ${meterRow("Market Signal", marketPct, market.label, market.tone === "good" ? "#138a4a" : (market.tone === "warn" ? "#b15518" : "#245ea8"))}
            </div>
          </div>

          <div class="subcard">
              <div class="subhead">ScoutingGrade Advanced Context</div>
              ${productionRows(p)}
            </div>

          <div class="subcard">
              <div class="subhead">${lens.title}</div>
              ${(lens.tags || []).length ? `<div class="chip-row">${(lens.tags || []).map((t) => `<span class="chip info">${t}</span>`).join("")}</div>` : ``}
              ${(lens.rows || []).map((item) => meterRow(item.label, item.pct, `${Number(item.pct).toFixed(0)}th pct`, "#1f5ea8") + `<div class="muted lens-copy">${item.detail}</div>`).join("")}
            </div>

          <div class="scout-block">
            <div class="subcard">
              <div class="subhead">Role / Scheme Fit</div>
              <div><strong>${role.role}</strong></div>
              <div class="muted">${role.scheme}</div>
              <div class="chip-row">
                ${(role.tags || []).map((t) => `<span class="chip info">${t}</span>`).join("") || `<span class="muted">No scheme tags</span>`}
              </div>
            </div>

            <div class="subcard">
              <div class="subhead">Rank Movement</div>
              <div class="chip-row">
                <span class="chip ${move > 0 ? "good" : move < 0 ? "warn" : "info"}">${moveText} (window)</span>
                ${topDrivers.map((d) => `<span class="chip info">${d.key} ${d.val >= 0 ? "+" : ""}${d.val.toFixed(2)}</span>`).join("")}
              </div>
              ${sparkline(p.rank_history || [])}
            </div>

            <div class="subcard">
              <div class="subhead">Historical Comp Panel</div>
              ${compLine("Floor", p.historical_comp_floor, "Depth/rotation outcome")}
              ${compLine("Median", p.historical_comp_median, "Starter outcome")}
              ${compLine("Ceiling", p.historical_comp_ceiling, "Impact starter / all-pro ceiling")}
              <div class="muted">Comp confidence: ${p.comp_confidence || "-"}</div>
            </div>
          </div>
        `;
        cards.appendChild(div);
      });
    };

    if (pool[0] && slots[0] && !slots[0].value) slots[0].value = pool[0].player_uid;
    if (pool[1] && slots[1] && !slots[1].value) slots[1].value = pool[1].player_uid;
    if (pool[2] && slots[2] && !slots[2].value) slots[2].value = pool[2].player_uid;
    if (pool[3] && slots[3] && !slots[3].value) slots[3].value = pool[3].player_uid;

    slots.forEach((el) => el?.addEventListener("change", () => {
      repopulateSlotOptions();
      render();
    }));
    slotSearches.forEach((input, idxNum) => input?.addEventListener("input", () => {
      repopulateSlotOptions();
      render();
      if (window.innerWidth <= 900) {
        document.querySelector(".compare-controls")?.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }));
    positionFilter?.addEventListener("change", () => {
      repopulateSlotOptions();
      render();
      if (window.innerWidth <= 900) {
        document.querySelector(".compare-controls")?.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
    repopulateSlotOptions();
    render();
  </script>
</BaseLayout>
